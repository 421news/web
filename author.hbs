{{> "site-footer"}}
<script>
(function() {
  var API_KEY = '420da6f85b5cc903b347de9e33';
  var authorSlug = location.pathname.match(/\/author\/([^/]+)/);
  if (!authorSlug) return;
  authorSlug = authorSlug[1];

  var LANG_FILTERS = {
    es: { tag: '-hash-en+-hash-zh+-hash-ja+-hash-ko+-hash-tr+-hash-pt+-hash-fr', title: 'Escrito por ' },
    en: { tag: 'hash-en', title: 'Written by ' },
    pt: { tag: 'hash-pt', title: 'Escrito por ' },
    fr: { tag: 'hash-fr', title: 'Écrit par ' },
    zh: { tag: 'hash-zh', title: '作者：' },
    ja: { tag: 'hash-ja', title: '著者：' },
    ko: { tag: 'hash-ko', title: '저자: ' },
    tr: { tag: 'hash-tr', title: 'Yazan: ' }
  };

  var grid = document.getElementById('author-posts-grid');
  var btn = document.getElementById('load-more-author');
  var titleEl = document.getElementById('author-posts-title');
  var authorName = titleEl ? titleEl.textContent.replace('Escrito por ', '') : '';
  var currentLang = 'es';
  var nextPage = null;
  var loading = false;

  function buildFilter(lang) {
    var f = 'primary_author:' + authorSlug;
    var parts = LANG_FILTERS[lang].tag.split('+');
    parts.forEach(function(p) { f += '+tag:' + p; });
    return f;
  }

  function buildURL(lang, page) {
    return '/ghost/api/content/posts/?key=' + API_KEY +
      '&page=' + page +
      '&limit=24&include=authors,tags&order=published_at%20desc' +
      '&filter=' + encodeURIComponent(buildFilter(lang));
  }

  function fetchAndRender(lang, page, append) {
    if (loading) return;
    loading = true;
    btn.disabled = true;
    btn.textContent = lang === 'es' ? 'Cargando...' : 'Loading...';

    fetch(buildURL(lang, page), { headers: { 'Accept-Version': 'v5.0' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var posts = data.posts || [];
        var html = posts.map(window.renderCard).join('');
        if (append) {
          grid.insertAdjacentHTML('beforeend', html);
        } else {
          grid.innerHTML = html;
        }
        var pag = data.meta && data.meta.pagination;
        nextPage = pag ? pag.next : null;
        if (nextPage) {
          btn.style.display = 'block';
          btn.disabled = false;
          btn.textContent = (lang === 'es') ? 'Cargar más' : 'Load more';
        } else {
          btn.style.display = 'none';
        }
        if (!append && posts.length === 0) {
          grid.innerHTML = '<p style="opacity:0.5;padding:2rem 0;">No posts in this language.</p>';
        }
      })
      .catch(function() { btn.disabled = false; })
      .then(function() { loading = false; });
  }

  // Language filter buttons
  var buttons = document.querySelectorAll('.lang-filter-btn');
  buttons.forEach(function(b) {
    b.addEventListener('click', function() {
      var lang = b.getAttribute('data-lang');
      if (lang === currentLang) return;
      currentLang = lang;
      buttons.forEach(function(x) { x.classList.remove('is-active'); });
      b.classList.add('is-active');
      if (titleEl) titleEl.textContent = LANG_FILTERS[lang].title + authorName;
      fetchAndRender(lang, 1, false);
    });
  });

  // Load more
  btn.addEventListener('click', function() {
    if (nextPage) fetchAndRender(currentLang, nextPage, true);
  });

  // Detect referrer language
  var ref = document.referrer;
  var refMatch = ref && ref.match(/\/([a-z]{2})\//);
  var initLang = (refMatch && LANG_FILTERS[refMatch[1]]) ? refMatch[1] : 'es';

  // Activate correct button
  if (initLang !== 'es') {
    buttons.forEach(function(b) {
      b.classList.remove('is-active');
      if (b.getAttribute('data-lang') === initLang) b.classList.add('is-active');
    });
    currentLang = initLang;
    if (titleEl) titleEl.textContent = LANG_FILTERS[initLang].title + authorName;
  }

  // Initial load
  fetchAndRender(currentLang, 1, false);
})();
</script>

<script>
// Linkify "tres libros..." en la bio de Juan Ruocco → /es/juan-ruocco-libros/
(function () {
  var bio = document.querySelector('p.post-author-bio[data-author-slug="juan-ruocco"]');
  if (!bio) return;
  var re = /(Publiqué\s+)([^.]*libros[^.]*)(\.)/i;
  var m = bio.innerHTML.match(re);
  if (!m) return;
  bio.innerHTML = bio.innerHTML.replace(
    re,
    '$1<a href="/es/juan-ruocco-libros/" class="bio-libros-link">$2</a>$3'
  );
})();
</script>
