{{!< default}}


  <div class="page-wrapper">
    {{> "site-nav-intl"}}
    <main style="min-height: 80vh;">
      {{#page}}
        {{> "section-hero"
            eyebrow="421 · page"
            eyebrowId="page-intl-eyebrow"
            title=title
            titleId="page-intl-title"
            tesis=excerpt}}
      {{/page}}
      <div class="pv-large">
        <div class="global-container">
          {{#page}}
            {{#if feature_image}}
              <img src="{{feature_image}}" loading="lazy" alt="{{title}}" class="page-hero_img">
            {{/if}}
          {{/page}}
          <div class="pt-medium">
            <div class="rich-text w-richtext">{{#page}}{{content}}{{/page}}</div>
          </div>
        </div>
      </div>
    </main>
    {{> "site-footer"}}
  </div>

  <script defer>
    document.addEventListener('DOMContentLoaded', function() {
      var m = window.location.pathname.match(/^\/([a-z]{2})\//);
      var lang = m ? m[1] : 'en';

      var i18n = {
        en: { eyebrow: '421 · page', title: 'What is 421' },
        pt: { eyebrow: '421 · página', title: 'O que é 421' },
        fr: { eyebrow: '421 · page', title: 'Qu’est-ce que 421' },
        zh: { eyebrow: '421 · 页面', title: '421是什么' },
        ja: { eyebrow: '421 · ページ', title: '421とは' },
        ko: { eyebrow: '421 · 페이지', title: '421이란' },
        tr: { eyebrow: '421 · sayfa', title: '421 nedir' }
      };

      var t = i18n[lang];
      if (t) {
        var eyeEl = document.getElementById('page-intl-eyebrow');
        var titleEl = document.getElementById('page-intl-title');
        if (eyeEl) eyeEl.textContent = t.eyebrow;
        if (titleEl) titleEl.textContent = t.title;
      }
    });
  </script>
