{{!< default}}

<style>
  /* Full-viewport layout for this page only */
  #community-page {
    height: 100vh;
    padding-top: 96px; /* .site-header is fixed */
    display: flex;
    flex-direction: column;
    overflow: hidden; /* prevent page scrolling */
  }

  body {
    overflow: hidden; /* keep header/footer visible without scroll */
  }

  #community-page > main {
    flex: 1;
    min-height: 0;
    overflow: hidden;
    padding: 0;
  }

  #community-page footer.site-footer {
    flex-shrink: 0;
  }

  #community-game-wrap {
    position: relative;
    min-height: 0;
    height: 100%;
    width: 100vw;
    max-width: none;
    margin: 0;
    background: #0a0a0a;
    border-radius: 0;
    overflow: hidden;
    box-shadow: none;
  }

  #community-frame {
    display: none;
    width: 100%;
    height: 100%;
    border: none;
    vertical-align: middle;
  }

  #community-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: #6ee7b7;
    font-family: monospace;
    font-size: 1.2rem;
    padding: 2rem;
    text-align: center;
    background: #0a0a0a;
  }

  #community-mobile-notice {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 2rem;
    text-align: center;
    color: #EAE6E1;
    font-family: monospace;
    background: #0a0a0a;
  }

  #community-mobile-notice h2 {
    font-size: 1.3rem;
    color: #6ee7b7;
    margin-bottom: 1rem;
  }

  #community-mobile-notice p {
    font-size: 1rem;
    line-height: 1.6;
    max-width: 320px;
    color: #EAE6E1;
  }

  @media (max-width: 768px) {
    #community-mobile-notice {
      display: flex;
      justify-content: flex-start;
      padding-top: 25vh;
    }
    #community-game-wrap {
      display: none;
    }
    #community-page footer.site-footer {
      display: none;
    }
  }
</style>

<div class="page-wrapper" id="community-page">
  {{> "general-styling"}}
  {{> "site-nav-es"}}
  <main>
    <div id="community-mobile-notice">
      <h2>El Bosque aún no está disponible para una experiencia mobile</h2>
      <p>Para entrar al Bosque, visitá esta página desde una computadora.</p>
    </div>
    <div id="community-game-wrap">
      <div id="community-loading">Entrando al bosque...</div>
      <iframe
        id="community-frame"
        src="https://421-community-world-client.vercel.app/"
        allow="autoplay"
        title="421 — juego"
      ></iframe>
    </div>
  </main>

  {{> "site-footer"}}
</div>

<script>
(function () {
  const iframe = document.getElementById('community-frame');
  const loading = document.getElementById('community-loading');
  const GAME_ORIGIN = 'https://421-community-world-client.vercel.app/';

  window.addEventListener('message', async function (event) {
    if (event.origin !== GAME_ORIGIN) return;
    if (event.data && event.data.type === '421_REQUEST_AUTH') {
      await sendToken();
    }
  });

  async function sendToken() {
    try {
      const res = await fetch('/members/api/session', { credentials: 'include' });
      if (res.status === 204 || !res.ok) {
        iframe.contentWindow.postMessage({ type: '421_AUTH_FAILED' }, GAME_ORIGIN);
        loading.innerHTML =
          '<p>Necesitás estar suscrito a 421 para entrar.</p>' +
          '<a href="/subscribe/" style="color:#6ee7b7;margin-top:1rem;display:inline-block;">Suscribite acá</a>';
        return;
      }
      const token = await res.text();
      iframe.contentWindow.postMessage({ type: '421_AUTH', token }, GAME_ORIGIN);
    } catch (err) {
      loading.textContent = 'Error al conectar. Intentá recargar la página.';
    }
  }

  iframe.addEventListener('load', async function () {
    await sendToken();
    iframe.style.display = 'block';
    loading.style.display = 'none';
  });
})();
</script>



