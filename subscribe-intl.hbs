{{!< default}}

    <link href="{{asset "css/suscribite.css"}}" rel="stylesheet" type="text/css">
    <div class="page-wrapper">
      {{> "general-styling"}}
      {{> "site-nav-intl"}}

      <div class="sub-page">
        <div class="sub-container">

          <div id="sub-section-plan">

            <div class="sub-hero">
              <span class="sub-hero-eyebrow" data-i18n="eyebrow">✨ Become a Wizard</span>
              <h1 class="sub-hero-title"><span data-i18n="h1pre">Read </span><span class="sub-hero-accent" data-i18n="h1accent">Revista 421 before anyone else</span><span data-i18n="h1post"> and back the project</span></h1>
              <p class="sub-hero-subtitle" data-i18n-html="subtitle">Every new issue reaches Wizards <strong>one month before</strong> the public. Plus commenting on articles, the Magic app and the Monthly Council with Juan Ruocco.</p>
              <div class="sub-hero-proof" data-i18n="proof">228 wizards · 5,031 readers</div>
            </div>
            <hr class="sub-gradient-divider">

            <div class="tier-grid">

              <!-- FREE TIER -->
              <div class="tier">
                <h2 class="tier-name" data-i18n="freeName">Free</h2>
                <p class="tier-tagline" data-i18n="freeTagline">To start reading 421</p>
                <div class="tier-price"><span class="tier-price-amount">$0</span></div>
                <ul class="tier-benefits" data-i18n-list="freeBenefits">
                  <li>Access to all articles on the site</li>
                  <li>Weekly newsletter with the best of 421</li>
                  <li>Download of released magazines (back issues)</li>
                  <li>Access to the 421 Canon and reading routes</li>
                </ul>
                <button class="btn-outline" id="btn-free" data-i18n="freeCta">Sign up for free →</button>
                <p class="tier-fine" data-i18n="freeFine">No card · Cancel anytime</p>
              </div>

              <!-- PAID TIER -->
              <div class="tier featured" id="sub-plan-card">
                <span class="tier-badge" data-i18n="badge">Most popular</span>
                <h2 class="tier-name" data-i18n="wizardName">Wizard</h2>
                <p class="tier-tagline" data-i18n="wizardTagline">Full access + back the project</p>

                <div class="plan-toggle">
                  <button class="plan-toggle-btn active" id="toggle-monthly" data-i18n="monthly">Monthly</button>
                  <button class="plan-toggle-btn" id="toggle-yearly">
                    <span data-i18n="annual">Annual</span>
                    <span class="toggle-badge">-17%</span>
                  </button>
                </div>

                <div id="plan-price" class="tier-price">
                  <span class="tier-price-amount" id="price-amount">...</span>
                  <span class="tier-price-period" id="price-period">USD / month</span>
                  <div class="plan-price-detail" id="price-detail"></div>
                </div>

                <ul class="tier-benefits" data-i18n-list="wizardBenefits">
                  <li class="tier-benefit-featured">📕 Read <strong>Revista 421 #<span data-revista-numero>14</span></strong> in PDF <strong>one month before</strong> public release</li>
                  <li>Comment and join discussions on every article</li>
                  <li><strong>Monthly Council</strong>: video call with <a href="/author/juan-ruocco/">Juan Ruocco</a> and other wizards</li>
                  <li>Access to the <a href="https://mtg.421.news">Magic 421 app</a></li>
                </ul>

                <button class="btn-gradient" id="btn-suscribirme" data-i18n="wizardCta">Become a Wizard →</button>
                <p class="tier-fine" data-i18n="wizardFine">Pay with international card (Stripe, USD)</p>
              </div>

            </div>

            <section class="sub-faq">
              <h2 data-i18n="faqTitle">FAQ</h2>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ1">What exactly is "early access" to the magazine?</summary>
                <p data-i18n="faqA1">Each new issue of Revista 421 is released first to Wizards only, as a PDF. One month later it's released to the rest of the public.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ2">How do I cancel?</summary>
                <p data-i18n="faqA2">From your account, anytime. No commitment, no questions. You keep access until the end of the paid period.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ3">What about old issues of the magazine?</summary>
                <p data-i18n-html="faqA3">They remain available to everyone (free). Only the <strong>latest issue</strong> is reserved for Wizards during its first month.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ4">What's the Monthly Council?</summary>
                <p data-i18n="faqA4">A roughly 1-hour video call with Juan Ruocco and other Wizards. Open discussion, editorial proposals, debates. Announced in advance via newsletter.</p>
              </details>
            </section>
          </div>

        </div>
      </div>

      {{> "site-footer"}}
    </div>

