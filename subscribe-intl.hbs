            faqQ1:'Dergiye "erken erişim" tam olarak ne?', faqA1:'Her yeni Revista 421 sayısı önce sadece aboneler için PDF olarak yayınlanır. Bir ay sonra halka açılır.',
            faqQ2:'Nasıl iptal ederim?', faqA2:'Hesabınızdan istediğiniz zaman. Taahhüt yok, soru yok. Ödeme döneminin sonuna kadar erişim sağlanır.',
            faqQ3:'Eski sayılar ne olacak?', faqA3:'Herkese ücretsiz olarak açık kalır. Sadece <strong>en son sayı</strong> ilk ay boyunca aboneler için ayrılmıştır.',
            faqQ4:'Aylık Konsey neyi içerir?', faqA4:'Juan Ruocco ve diğer abonelerle yaklaşık 1 saatlik görüntülü görüşme. Açık sohbet, editöryal öneriler, tartışmalar. E-posta ile önceden duyurulur.'
          }
        };

        var t = i18n[lang] || i18n.en;

        // Apply translations via data-i18n / data-i18n-html / data-i18n-list / data-i18n-ph
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          if (t[key] !== undefined) el.textContent = t[key];
        });
        document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-html');
          if (t[key] !== undefined) el.innerHTML = t[key];
        });
        document.querySelectorAll('[data-i18n-ph]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-ph');
          if (t[key] !== undefined) el.setAttribute('placeholder', t[key]);
        });
        document.querySelectorAll('[data-i18n-list]').forEach(function(ul) {
          var key = ul.getAttribute('data-i18n-list');
          var items = t[key];
          if (!Array.isArray(items)) return;
          var lis = ul.querySelectorAll('li');
          for (var i = 0; i < lis.length && i < items.length; i++) {
            // Preserve .tier-benefit-featured class if present
            var keepClass = lis[i].className;
            lis[i].innerHTML = items[i];
            if (keepClass) lis[i].className = keepClass;
          }
        });

        // Update revista # dynamically
        fetch('/ghost/api/content/pages/slug/revista-421/?key=420da6f85b5cc903b347de9e33&formats=html', { headers: { 'Accept-Version': 'v5.0' } })
          .then(function(r){ return r.json(); })
          .then(function(d){
            var p = d.pages && d.pages[0];
            if (!p || !p.html) return;
            var doc = new DOMParser().parseFromString(p.html, 'text/html');
            var h2 = doc.querySelector('h2');
            if (!h2) return;
            var mm = h2.textContent.trim().match(/#(\d+)/);
            if (!mm) return;
            document.querySelectorAll('[data-revista-numero]').forEach(function(el){ el.textContent = mm[1]; });
          })
          .catch(function(){});

        // Tier price fetching + toggle logic
        var currentCadence = 'monthly';
        var tierData = null;

        fetch('/ghost/api/content/tiers/?key=420da6f85b5cc903b347de9e33', { headers: { 'Accept-Version': 'v5.0' } })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var tiers = data.tiers || [];
            for (var i = 0; i < tiers.length; i++) {
              if (tiers[i].type === 'paid' && tiers[i].active) { tierData = tiers[i]; break; }
            }
            if (tierData) updatePriceDisplay();
          });

        function formatPrice(cents) {
          var dollars = cents / 100;
          return '$' + (dollars % 1 === 0 ? dollars : dollars.toFixed(2));
        }

        function updatePriceDisplay() {
          if (!tierData) return;
          var amountEl = document.getElementById('price-amount');
          var periodEl = document.getElementById('price-period');
          var detailEl = document.getElementById('price-detail');
          if (currentCadence === 'yearly') {
            amountEl.textContent = formatPrice(tierData.yearly_price);
            periodEl.textContent = t.year;
            var monthlyTotal = tierData.monthly_price * 12;
            detailEl.innerHTML = '<span class="striked">' + formatPrice(monthlyTotal) + '</span> — ' + t.save;
          } else {
            amountEl.textContent = formatPrice(tierData.monthly_price);
            periodEl.textContent = t.month;
            detailEl.textContent = t.nocommit;
          }
        }

        var toggleM = document.getElementById('toggle-monthly');
        var toggleY = document.getElementById('toggle-yearly');
        toggleM.addEventListener('click', function() {
          currentCadence = 'monthly';
          toggleM.classList.add('active');
          toggleY.classList.remove('active');
          updatePriceDisplay();
        });
        toggleY.addEventListener('click', function() {
          currentCadence = 'yearly';
          toggleY.classList.add('active');
          toggleM.classList.remove('active');
          updatePriceDisplay();
        });

        document.getElementById('btn-suscribirme').addEventListener('click', function() {
          if (!tierData) return;
          if (typeof gtag === 'function') gtag('event','begin_checkout',{event_category:'subscription',event_label:'subscribe_'+currentCadence+'_intl_'+lang});
          window.location.hash = '#/portal/signup/' + tierData.id + '/' + currentCadence;
        });

        document.getElementById('btn-free').addEventListener('click', function() {
          if (typeof gtag === 'function') gtag('event','sign_up_intent',{event_category:'subscription',event_label:'free_register_intl_'+lang});
          window.location.hash = '#/portal/signup/free';
        });

        // ===== Inline login (magic link, signin) =====
        var loginForm = document.getElementById('inline-login');
        var loginEmail = document.getElementById('login-email');
        var loginSubmit = document.getElementById('login-submit');

        function setLoginMsg(text, cls) {
          var el = document.getElementById('login-msg');
          el.textContent = text;
          el.className = 'login-msg' + (cls ? ' ' + cls : '');
        }

        document.getElementById('btn-login-toggle').addEventListener('click', function() {
          loginForm.classList.add('open');
          setLoginMsg('', '');
          loginEmail.focus();
        });
        document.getElementById('btn-login-back').addEventListener('click', function() {
          loginForm.classList.remove('open');
          setLoginMsg('', '');
        });

        function getIntegrityToken() {
          return fetch('/members/api/integrity-token/', { credentials: 'same-origin' })
            .then(function(r) { return r.ok ? r.text() : ''; })
            .catch(function() { return ''; });
        }

        loginForm.addEventListener('submit', function(e) {
          e.preventDefault();
          var email = loginEmail.value.trim();
          if (!email) return;
          loginSubmit.disabled = true;
          setLoginMsg(t.loginSending, '');
          if (typeof gtag === 'function') gtag('event','login_magiclink_request',{event_category:'subscription',event_label:'subscribe_intl_'+lang});
          getIntegrityToken().then(function(token) {
            var body = { email: email, emailType: 'signin' };
            if (token) body.integrityToken = token;
            return fetch('/members/api/send-magic-link/', {
              method: 'POST',
              credentials: 'same-origin',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(body)
            });
          })
          .then(function(r) {
            if (!r.ok) throw new Error('http ' + r.status);
            setLoginMsg(t.loginSent, 'ok');
          })
          .catch(function() {
            setLoginMsg(t.loginError, 'err');
            loginSubmit.disabled = false;
          });
        });
      });
    </script>
