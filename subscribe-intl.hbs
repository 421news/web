{{!< default}}

    <link href="{{asset "css/suscribite.css"}}" rel="stylesheet" type="text/css">
    <div class="page-wrapper">
      {{> "general-styling"}}
      {{> "site-nav-intl"}}

      <div class="sub-page">
        <div class="sub-container">

          <div id="sub-section-plan">

            <div class="sub-hero">
              <span class="sub-hero-eyebrow" data-i18n="eyebrow">✦ Join 421</span>
              <h1 class="sub-hero-title" data-i18n="h1">Read 421 and back the project</h1>
              <p class="sub-hero-subtitle" data-i18n-html="subtitle">Sign up for free to read, or subscribe for full access and help us <strong>hire new writers</strong> every month.</p>
              <div class="sub-hero-proof" data-i18n="proof">228 subscribers · 5,031 readers</div>
            </div>
            <hr class="sub-gradient-divider">

            <div class="tier-grid">

              <!-- REGISTER + LOGIN -->
              <div class="tier">
                <h2 class="tier-name" data-i18n="registerName">Sign up</h2>
                <p class="tier-tagline" data-i18n="registerTagline">Create your free account and start reading 421</p>
                <div class="tier-free-label" data-i18n="freeLabel">Free</div>
                <ul class="tier-benefits" data-i18n-list="registerBenefits">
                  <li>Download of <strong>released</strong> magazines (back issues)</li>
                  <li>Keep your session on any device</li>
                </ul>

                <div class="tier-actions">
                  <button class="btn-outline" id="btn-free" data-i18n="registerCta">Sign up for free</button>
                  <div class="tier-actions-divider" data-i18n="or">or</div>
                  <button class="btn-ghost" id="btn-login-toggle" data-i18n="loginToggle">I have an account · Log in</button>

                  <form class="inline-login" id="inline-login">
                    <input type="email" id="login-email" data-i18n-ph="loginPlaceholder" placeholder="you@email.com" required autocomplete="email">
                    <button type="submit" class="btn-outline" id="login-submit" data-i18n="loginSubmit">Send me the login link</button>
                    <div class="login-msg" id="login-msg"></div>
                    <button type="button" class="inline-login-back" id="btn-login-back" data-i18n="loginBack">&larr; Back</button>
                  </form>
                </div>
              </div>

              <!-- SUBSCRIPTION -->
              <div class="tier featured" id="sub-plan-card">
                <span class="tier-badge" data-i18n="badge">Recommended</span>
                <h2 class="tier-name" data-i18n="subscribeName">Subscribe</h2>
                <p class="tier-tagline" data-i18n="subscribeTagline">Full access + back the project</p>

                <div class="plan-toggle">
                  <button class="plan-toggle-btn active" id="toggle-monthly" data-i18n="monthly">Monthly</button>
                  <button class="plan-toggle-btn" id="toggle-yearly">
                    <span data-i18n="annual">Annual</span>
                    <span class="toggle-badge">-17%</span>
                  </button>
                </div>

                <div id="plan-price" class="tier-price">
                  <span class="tier-price-amount" id="price-amount">...</span>
                  <span class="tier-price-period" id="price-period">USD / month</span>
                  <div class="plan-price-detail" id="price-detail"></div>
                </div>

                <ul class="tier-benefits" data-i18n-list="subscribeBenefits">
                  <li class="tier-benefit-featured">📕 Read <strong>Revista 421 #<span data-revista-numero>14</span></strong> in PDF <strong>one month before</strong> public release</li>
                  <li>Comment and join discussions on every article</li>
                  <li><strong>Monthly Council</strong>: video call with <a href="/author/juan-ruocco/">Juan Ruocco</a> and other subscribers</li>
                  <li>Access to the <a href="https://mtg.421.news">Magic 421 app</a></li>
                </ul>

                <button class="btn-gradient" id="btn-suscribirme" data-i18n="subscribeCta">Subscribe →</button>
              </div>

            </div>

            <section class="sub-faq">
              <h2 data-i18n="faqTitle">FAQ</h2>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ1">What exactly is "early access" to the magazine?</summary>
                <p data-i18n="faqA1">Each new issue of Revista 421 is released first to subscribers only, as a PDF. One month later it's released to the rest of the public.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ2">How do I cancel?</summary>
                <p data-i18n="faqA2">From your account, anytime. No commitment, no questions. You keep access until the end of the paid period.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ3">What about old issues of the magazine?</summary>
                <p data-i18n-html="faqA3">They remain available to everyone (free). Only the <strong>latest issue</strong> is reserved for subscribers during its first month.</p>
              </details>
              <details class="sub-faq-item">
                <summary data-i18n="faqQ4">What's the Monthly Council?</summary>
                <p data-i18n="faqA4">A roughly 1-hour video call with Juan Ruocco and other subscribers. Open discussion, editorial proposals, debates. Announced in advance by email.</p>
              </details>
            </section>
          </div>

        </div>
      </div>

      {{> "site-footer"}}
    </div>

