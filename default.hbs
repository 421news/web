    <link rel="alternate" hreflang="en" href="https://www.421.news/en/" />
    <link rel="alternate" hreflang="zh" href="https://www.421.news/zh/" />
    <link rel="alternate" hreflang="ja" href="https://www.421.news/ja/" />
    <link rel="alternate" hreflang="ko" href="https://www.421.news/ko/" />
    <link rel="alternate" hreflang="tr" href="https://www.421.news/tr/" />
    <link rel="alternate" hreflang="pt" href="https://www.421.news/pt/" />
    <link rel="alternate" hreflang="fr" href="https://www.421.news/fr/" />
    <link rel="alternate" hreflang="x-default" href="https://www.421.news/" />
    {{/unless}}{{/unless}}{{/unless}}{{/unless}}{{/unless}}
