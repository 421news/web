    {{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/post}}{{/is}}
    <script>
      (function() {
        var p = window.location.pathname;
        var langs = ['en','zh','ja','ko','tr','pt','fr'];
        for (var i = 0; i < langs.length; i++) {
          if (p.startsWith('/' + langs[i] + '/')) {
            document.documentElement.lang = langs[i];
            break;
          }
        }
      })();
    </script>
