    {{!-- Server-side hreflang: landing (/) AND collection homepages (/es/, /en/, /pt/, /fr/, /zh/, /ja/, /ko/, /tr/) --}}
    {{!-- Critical: must render on ALL collection homes for hreflang reciprocity. Without it, Google picks / as canonical for /es/. --}}
    {{!-- Uses {{#unless}} chain since {{#is "home,index"}} alone is unreliable across Ghost versions. Excludes posts/pages/tags/authors/error pages. --}}
