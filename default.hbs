    {{else}}{{#has tag="#ja"}}
    <link rel="alternate" hreflang="ja" href="{{url absolute=true}}" />
    {{else}}{{#has tag="#ko"}}
    <link rel="alternate" hreflang="ko" href="{{url absolute=true}}" />
    {{else}}{{#has tag="#tr"}}
    <link rel="alternate" hreflang="tr" href="{{url absolute=true}}" />
    {{else}}{{#has tag="#pt"}}
