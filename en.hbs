{{!< default}}

<script>
  document.title = '421 | Quality content for your cognitive diet';
  (function() {
    var enDesc = 'Argentine digital media about culture, technology, games, and real life. Essays, features, guides, and interviews.';
    var enTitle = '421 | Quality content for your cognitive diet';
    function setMeta(attr, key, val) {
      var el = document.querySelector('meta[' + attr + '="' + key + '"]');
      if (el) { el.content = val; }
      else { var m = document.createElement('meta'); m.setAttribute(attr, key); m.content = val; document.head.appendChild(m); }
    }
    var img = 'https://www.421.news/content/images/2026/01/10_diciembre.jpg';
    setMeta('name', 'description', enDesc);
    setMeta('property', 'og:title', enTitle);
    setMeta('property', 'og:description', enDesc);
    setMeta('property', 'og:image', img);
    setMeta('property', 'og:url', 'https://www.421.news/en/');
    setMeta('property', 'og:type', 'website');
    setMeta('property', 'og:locale', 'en_US');
    setMeta('name', 'twitter:card', 'summary_large_image');
    setMeta('name', 'twitter:title', enTitle);
    setMeta('name', 'twitter:description', enDesc);
    setMeta('name', 'twitter:image', img);
  })();
</script>

<div class="page-wrapper">
  {{> "general-styling"}}
  {{> "site-nav-en"}}
  <main>
    <h1 class="sr-only">421 — Quality content for your cognitive diet</h1>

    <!-- FEATURED POST -->
    {{> "index-featured-post" languageFilter="'hash-en'"}}

    <!-- HIGHLIGHTED POSTS -->
    {{> "index-highlighted-posts-en"}}

    <!-- MOST READ (dynamic, GA4 historical) -->
    {{> "index-most-read-en"}}

    <!-- FILE BROWSER NAVIGATION -->
    <div class="global-container pt-small pb-small">
      {{> "file-browser-en"}}
    </div>

    <!-- LAST POSTS -->
    {{> "last-posts-en"}}
  </main>

  {{> "site-footer" lang="en"}}

</div>
<script src="{{asset "js/pagination.js"}}" defer></script>
<script src="{{asset "js/home-ruta.js"}}" defer></script>
