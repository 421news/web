{{!< default}}

<div class="page-wrapper">
  {{> "general-styling"}}
  {{> "site-nav-intl"}}

  {{> "section-hero"
      eyebrow="421 · section"
      eyebrowId="canon-intl-eyebrow"
      title="Canon 421"
      titleId="canon-intl-title"
      meta="25 essential texts"
      metaId="canon-intl-meta"
      tesis="If 421 were a library, these would be the 25 books that never leave the shelf. The texts that best represent what we do, why we do it, and how we do it."
      tesisId="canon-intl-subtitle"}}

  <div class="canon-page">
    <div class="global-container">

      <!-- Canon container: JS will populate this -->
      <div id="canon-container" data-json="{{asset "data/rutas.json"}}"></div>

    </div>
  </div>

  {{> "site-footer"}}
</div>

<script>
(function() {
  var m = window.location.pathname.match(/^\/([a-z]{2})\//);
  var lang = m ? m[1] : 'en';
  var i18n = {
    en: { eyebrow: '421 · section', meta: '25 essential texts', title: 'Canon 421', sub: 'If 421 were a library, these would be the 25 books that never leave the shelf. The texts that best represent what we do, why we do it, and how we do it.' },
    pt: { eyebrow: '421 · seção', meta: '25 textos essenciais', title: 'Cânone 421', sub: 'Se o 421 fosse uma biblioteca, estes seriam os 25 livros que nunca saem da estante. Os textos que melhor representam o que fazemos, por que fazemos e como fazemos.' },
    fr: { eyebrow: '421 · section', meta: '25 textes essentiels', title: 'Canon 421', sub: 'Si 421 était une bibliothèque, voici les 25 livres qui ne quittent jamais l’étagère. Les textes qui représentent le mieux ce que nous faisons, pourquoi et comment.' },
    zh: { eyebrow: '421 · 栏目', meta: '25篇核心文章', title: '经典 421', sub: '如果421是一座图书馆，这就是永远不会离开书架的25本书。最能代表我们做什么、为什么做以及如何做的文章。' },
    ja: { eyebrow: '421 · セクション', meta: '必読25本', title: 'カノン 421', sub: '421が図書館だとしたら、これが棚から決して離れない25冊。私たちが何をし、なぜし、どのようにするかを最もよく表すテキスト。' },
    ko: { eyebrow: '421 · 섹션', meta: '필독 25편', title: '카논 421', sub: '421이 도서관이라면, 이것이 선반을 떠나지 않는25권의 책입니다. 우리가 무엇을, 왜, 어떻게 하는지를 가장 잘 보여주는 글들입니다.' },
    tr: { eyebrow: '421 · bölüm', meta: '25 temel metin', title: 'Kanon 421', sub: '421 bir kütüphane olsaydı, bunlar raftan hiç çıkmayacak 25 kitap olurdu. Ne yaptığımızı, neden yaptığımızı ve nasıl yaptığımızı en iyi temsil eden metinler.' }
  };
  var t = i18n[lang];
  if (t) {
    var eyeEl = document.getElementById('canon-intl-eyebrow');
    var titleEl = document.getElementById('canon-intl-title');
    var metaEl = document.getElementById('canon-intl-meta');
    var subEl = document.getElementById('canon-intl-subtitle');
    if (eyeEl) eyeEl.textContent = t.eyebrow;
    if (titleEl) titleEl.textContent = t.title;
    if (metaEl) metaEl.textContent = t.meta;
    if (subEl) subEl.textContent = t.sub;
  }
})();
window.__rutasJson = fetch('{{asset "data/rutas.json"}}').then(function(r){return r.json()});
</script>
<script src="{{asset "js/rutas.js"}}" defer></script>
