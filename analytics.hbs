{{!< default}}

<meta name="robots" content="noindex, nofollow">
<link href="{{asset "css/analytics.css"}}" rel="stylesheet" type="text/css">

<script>
document.title = 'Analytics | 421.news';
document.documentElement.classList.add('is-analytics');
</script>

<div class="page-wrapper">
  {{> "general-styling"}}

  <div class="analytics-page">
    <div class="global-container">

      <!-- Auth: Loading -->
      <div id="auth-loading" class="analytics-auth-state">
        <div class="analytics-auth-icon">&#x23F3;</div>
        <p>Verificando acceso...</p>
      </div>

      <!-- Auth: Denied -->
      <div id="auth-denied" class="analytics-auth-state" style="display:none;">
        <div class="analytics-auth-icon">&#x1F512;</div>
        <h2>Acceso restringido</h2>
        <p>Esta p&aacute;gina es solo para el equipo de 421.</p>
        <a href="/es/" class="analytics-back-link">&larr; Volver al inicio</a>
      </div>

      <!-- Dashboard -->
      <div id="dashboard" style="display:none;">

        <!-- View tabs: Analytics | Revenue -->
        <div class="analytics-toptabs">
          <button class="analytics-toptab active" data-view="analytics">Analytics</button>
          <button class="analytics-toptab" data-view="revenue">Revenue</button>
        </div>

        <!-- ===== ANALYTICS VIEW ===== -->
        <div id="analytics-view">
        <div class="analytics-hero">
          <h1 class="analytics-title">Analytics</h1>
          <p class="analytics-subtitle">Datos del <span id="analytics-range"></span> &middot; Actualizado <span id="analytics-generated"></span></p>
        </div>
        <hr class="analytics-gradient-divider">

        <!-- Global month filters -->
        <div class="analytics-global-filters">
          <div class="analytics-filters" id="month-filters"></div>
        </div>

        <!-- Summary cards -->
        <div class="analytics-cards" id="analytics-cards"></div>

        <!-- Traffic -->
        <div class="analytics-section">
          <div class="analytics-section-header">
            <div class="analytics-section-titlerow">
              <h2>Tr&aacute;fico</h2>
              <button class="analytics-collapse-btn" data-collapse="traffic-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
            </div>
            <div class="analytics-granularity" id="granularity-toggle"></div>
          </div>
          <div id="traffic-body">
            <div class="analytics-chart-container">
              <canvas id="monthly-chart"></canvas>
            </div>
            <div class="analytics-subsection">
              <button class="analytics-collapse-bar is-collapsed" data-collapse="monthly-table-wrap">
                <span class="analytics-collapse-chevron">&#x25BE;</span>
                <span>Tabla detallada</span>
              </button>
              <div id="monthly-table-wrap" class="analytics-collapsed"></div>
            </div>
          </div>
        </div>

        <!-- Channels -->
        <div class="analytics-section">
          <div class="analytics-section-header">
            <div class="analytics-section-titlerow">
              <h2>Canales de adquisici&oacute;n</h2>
              <button class="analytics-collapse-btn" data-collapse="channels-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
            </div>
          </div>
          <div id="channels-body" class="analytics-channels-grid">
            <div class="analytics-donut-container">
              <canvas id="channel-chart"></canvas>
            </div>
            <div id="channel-legend" class="analytics-channel-legend"></div>
          </div>
        </div>

        <!-- Conversions / subscribe funnel -->
        <div class="analytics-section" id="conversions-section">
          <div class="analytics-section-header">
            <div class="analytics-section-titlerow">
              <h2>Conversiones</h2>
              <button class="analytics-collapse-btn" data-collapse="funnel-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
            </div>
          </div>
          <div id="funnel-body" class="analytics-funnel-grid">
            <div>
              <h3 class="analytics-subhead">Puntos de suscripci&oacute;n &middot; clicks</h3>
              <div id="cta-breakdown" class="analytics-cta-list"></div>
            </div>
            <div>
              <h3 class="analytics-subhead">Embudo</h3>
              <div id="funnel-steps" class="analytics-funnel"></div>
            </div>
          </div>
        </div>

        <!-- Devices & countries -->
        <div class="analytics-section" id="geo-section">
          <div class="analytics-section-header">
            <div class="analytics-section-titlerow">
              <h2>Dispositivos y pa&iacute;ses</h2>
              <button class="analytics-collapse-btn" data-collapse="geo-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
            </div>
          </div>
          <div id="geo-body" class="analytics-geo-grid">
            <div class="analytics-devices-col">
              <h3 class="analytics-subhead">Dispositivos</h3>
              <div class="analytics-donut-container analytics-donut-sm">
                <canvas id="device-chart"></canvas>
              </div>
              <div id="device-legend" class="analytics-channel-legend"></div>
            </div>
            <div class="analytics-countries-col">
              <h3 class="analytics-subhead">Top pa&iacute;ses</h3>
              <div id="country-list" class="analytics-country-list"></div>
            </div>
          </div>
        </div>

        <!-- Content: tabs + lang + search -->
        <div class="analytics-section">
          <div class="analytics-section-header">
            <div class="analytics-section-titlerow">
              <h2>Contenido</h2>
              <button class="analytics-collapse-btn" data-collapse="content-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
            </div>
            <div class="analytics-toolbar">
              <div class="analytics-tabs">
                <button class="analytics-tab active" data-tab="articles">Art&iacute;culos</button>
                <button class="analytics-tab" data-tab="pages">P&aacute;ginas</button>
              </div>
              <div class="analytics-lang-selector">
                <button class="analytics-lang active" data-lang="all">Todos</button>
                <button class="analytics-lang" data-lang="es">ES</button>
                <button class="analytics-lang" data-lang="en">EN</button>
              </div>
            </div>
            <input type="text" id="content-search" placeholder="Buscar..." class="analytics-search-input">
          </div>
          <div id="content-body">
            <div class="analytics-table-scroll">
              <table class="analytics-table" id="content-table">
                <thead>
                  <tr>
                    <th>#</th>
                    <th id="col-title">Art&iacute;culo</th>
                    <th class="analytics-num analytics-sortable" data-sort="pv">Pageviews <span class="analytics-sort-arrow">&#x25BC;</span></th>
                    <th class="analytics-num analytics-sortable" data-sort="u">Usuarios</th>
                    <th class="analytics-num analytics-sortable" data-sort="d">Duraci&oacute;n</th>
                  </tr>
                </thead>
                <tbody id="content-tbody"></tbody>
              </table>
            </div>
            <div id="content-pagination" class="analytics-pagination"></div>
          </div>
        </div>
        </div><!-- /#analytics-view -->

        <!-- ===== REVENUE VIEW ===== -->
        <div id="revenue-view" style="display:none;">
          <div class="analytics-hero">
            <h1 class="analytics-title">Revenue &amp; Suscriptores</h1>
            <p class="analytics-subtitle">Snapshot <span id="revenue-date"></span> &middot; Blue ref <span id="revenue-blue"></span> &middot; <span id="revenue-source"></span></p>
          </div>
          <hr class="analytics-gradient-divider">

          <!-- Summary cards -->
          <div class="analytics-cards" id="revenue-cards"></div>

          <!-- Growth -->
          <div class="analytics-section">
            <div class="analytics-section-header">
              <div class="analytics-section-titlerow">
                <h2>Crecimiento de suscriptores pagos</h2>
                <button class="analytics-collapse-btn" data-collapse="revenue-growth-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
              </div>
            </div>
            <div id="revenue-growth-body" class="analytics-chart-container">
              <canvas id="revenue-growth-chart"></canvas>
            </div>
          </div>

          <!-- Revenue cobrado -->
          <div class="analytics-section">
            <div class="analytics-section-header">
              <div class="analytics-section-titlerow">
                <h2>Revenue cobrado</h2>
                <button class="analytics-collapse-btn" data-collapse="revenue-rev-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
              </div>
            </div>
            <div id="revenue-rev-body" class="analytics-chart-container">
              <canvas id="revenue-rev-chart"></canvas>
            </div>
          </div>

          <!-- Desglose por plan -->
          <div class="analytics-section">
            <div class="analytics-section-header">
              <div class="analytics-section-titlerow">
                <h2>Desglose por plan</h2>
                <button class="analytics-collapse-btn" data-collapse="revenue-tier-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
              </div>
            </div>
            <div id="revenue-tier-body" class="analytics-channels-grid">
              <div class="analytics-donut-container">
                <canvas id="revenue-tier-chart"></canvas>
              </div>
              <div id="revenue-tier-legend" class="analytics-channel-legend"></div>
            </div>
          </div>

          <!-- Histórico semanal -->
          <div class="analytics-section">
            <div class="analytics-section-header">
              <div class="analytics-section-titlerow">
                <h2>Hist&oacute;rico semanal</h2>
                <button class="analytics-collapse-btn is-collapsed" data-collapse="revenue-hist-body" aria-label="Contraer secci&oacute;n">&#x25BE;</button>
              </div>
            </div>
            <div id="revenue-hist-body" class="analytics-table-scroll analytics-collapsed">
              <table class="analytics-table" id="revenue-hist-table">
                <thead>
                  <tr>
                    <th>Semana</th>
                    <th class="analytics-num">Total</th>
                    <th class="analytics-num">Pagos</th>
                    <th class="analytics-num">Ratio</th>
                    <th class="analytics-num">MP $5</th>
                    <th class="analytics-num">MP $50</th>
                    <th class="analytics-num">MP $10</th>
                    <th class="analytics-num">MP $100</th>
                    <th class="analytics-num">Stripe m.</th>
                    <th class="analytics-num">Stripe a.</th>
                    <th class="analytics-num">Rev. mens. (ARS)</th>
                    <th class="analytics-num">Rev. mens. (USD)</th>
                  </tr>
                </thead>
                <tbody id="revenue-hist-tbody"></tbody>
              </table>
            </div>
          </div>
        </div><!-- /#revenue-view -->
      </div>

    </div>
  </div>

</div>

<script>
window.__ga4Data = (function() {
  var themeUrl = '{{asset "data/ga4-data.json"}}';
  var renderUrl = 'https://webhook-hreflang.onrender.com/api/ga4-data.json';
  // Try Render first (5s timeout), fallback to theme asset
  var controller = new AbortController();
  var timer = setTimeout(function() { controller.abort(); }, 5000);
  return fetch(renderUrl, { signal: controller.signal })
    .then(function(r) { clearTimeout(timer); if (!r.ok) throw new Error(r.status); return r.json(); })
    .catch(function() { clearTimeout(timer); return fetch(themeUrl).then(function(r) { return r.json(); }); });
})();
window.__revenueData = (function() {
  var themeUrl = '{{asset "data/revenue-data.json"}}';
  var renderUrl = 'https://webhook-hreflang.onrender.com/api/revenue-data.json';
  var controller = new AbortController();
  var timer = setTimeout(function() { controller.abort(); }, 5000);
  return fetch(renderUrl, { signal: controller.signal })
    .then(function(r) { clearTimeout(timer); if (!r.ok) throw new Error(r.status); return r.json(); })
    .catch(function() { clearTimeout(timer); return fetch(themeUrl).then(function(r) { return r.json(); }); });
})();
(function() {
  function sha256(str) {
    return crypto.subtle.digest('SHA-256', new TextEncoder().encode(str.toLowerCase().trim()))
      .then(function(buf) { return Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join(''); });
  }
  Promise.all([
    fetch('/members/api/member/', { credentials: 'same-origin' }).then(function(r) { if (!r.ok) throw new Error('no'); return r.json(); }),
    window.__ga4Data
  ]).then(function(res) {
    var member = res[0];
    var data = res[1];
    var team = data && data.team ? data.team : [];
    return sha256(member.email).then(function(hash) {
      document.getElementById('auth-loading').style.display = 'none';
      if (team.indexOf(hash) !== -1) {
        document.getElementById('dashboard').style.display = '';
      } else {
        document.getElementById('auth-denied').style.display = '';
      }
    });
  }).catch(function() {
    document.getElementById('auth-loading').style.display = 'none';
    document.getElementById('auth-denied').style.display = '';
  });
})();
// View toggle: Analytics | Revenue (lazy-init revenue dashboard on first show)
(function() {
  var tabs = document.querySelectorAll('.analytics-toptab');
  for (var i = 0; i < tabs.length; i++) {
    tabs[i].addEventListener('click', function() {
      var view = this.getAttribute('data-view');
      for (var j = 0; j < tabs.length; j++) tabs[j].classList.remove('active');
      this.classList.add('active');
      document.getElementById('analytics-view').style.display = view === 'analytics' ? '' : 'none';
      document.getElementById('revenue-view').style.display = view === 'revenue' ? '' : 'none';
      if (view === 'revenue' && window.initRevenueDashboard) window.initRevenueDashboard();
    });
  }
})();
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js" defer></script>
<script src="{{asset "js/analytics-dashboard.js"}}" defer></script>
<script src="{{asset "js/revenue-dashboard.js"}}" defer></script>
