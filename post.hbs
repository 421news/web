{{!< default}}

{{#post}}
  {{#has tag="#en"}}
    {{> "post-en"}}
  {{else}}{{#has tag="#zh"}}
    {{> "post-intl" lang="zh"}}
  {{else}}{{#has tag="#ja"}}
    {{> "post-intl" lang="ja"}}
  {{else}}{{#has tag="#ko"}}
    {{> "post-intl" lang="ko"}}
  {{else}}{{#has tag="#tr"}}
    {{> "post-intl" lang="tr"}}
  {{else}}{{#has tag="#pt"}}
    {{> "post-intl" lang="pt"}}
  {{else}}{{#has tag="#fr"}}
    {{> "post-intl" lang="fr"}}
  {{else}}
    {{> "post-es"}}
  {{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}
{{/post}}

<script src="{{asset "js/reading-progress.js"}}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var linkContainer = document.getElementById('translation-link');
    if (!linkContainer) return;
    var englishMeta = document.querySelector('meta[name="english-version"]');
    var spanishMeta = document.querySelector('meta[name="spanish-version"]');
    var globeSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';
    if (englishMeta && englishMeta.content) {
      linkContainer.innerHTML = '<a href="/en/' + englishMeta.content + '" class="btn-translate" aria-label="Read in English">' + globeSvg + 'EN</a>';
    }
    if (spanishMeta && spanishMeta.content) {
      linkContainer.innerHTML = '<a href="/es/' + spanishMeta.content + '" class="btn-translate" aria-label="Leer en espa\u00F1ol">' + globeSvg + 'ES</a>';
    }
  });
</script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const featImg = document.querySelector('.post-featimg');
    if (featImg) {
      const bgImg = new Image();
      bgImg.onload = function() {
        featImg.classList.add('loaded');
      }
      const style = window.getComputedStyle(featImg);
      const bgUrl = style.backgroundImage.slice(4, -1).replace(/["']/g, "");
      bgImg.src = bgUrl;
    }
  })
</script>
