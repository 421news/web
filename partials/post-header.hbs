<div class="post-header">
  <div class="global-container">
    <div class="pt-xhuge">
      <div class="post-meta">
        <div class="hl-post_meta">
          <div class="plain-tags">
            {{#foreach tags}}
              <a href="{{#if ../lang}}/en{{else}}/es{{/if}}/tag/{{slug}}">{{name}}</a>{{#unless @last}}, {{/unless}}
            {{/foreach}}
          </div>
          <h1 class="flashy-h1 no-highlight">{{title}}</h1>
          {{> "author-box"}}
        </div>
        <div class="hl-post_meta">
          <p class="hl-post_preview">{{excerpt}}</p>
          {{reading_time}}
        </div>
      </div>
    </div>
  </div>
  <div style="display: flex; justify-content: center;">
    <img src="{{img_url feature_image size='l'}}"
      srcset="{{img_url feature_image size='s'}} 300w,
              {{img_url feature_image size='m'}} 600w,
              {{img_url feature_image size='l'}} 1000w,
              {{img_url feature_image size='xl'}} 2000w"
      sizes="(max-width: 768px) 100vw, 840px"
      alt="{{title}}"
      width="840"
      loading="eager"
      fetchpriority="high"
      style="width: 840px; max-width: 100%; height: auto;"
    />
  </div>
</div>