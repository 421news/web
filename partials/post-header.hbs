<div class="home-featured-post">
  {{#if feature_image}}
    <img
      class="home-featured-bg"
      src="{{img_url feature_image size='l'}}"
      srcset="{{img_url feature_image size='m'}} 600w,
              {{img_url feature_image size='l'}} 1000w,
              {{img_url feature_image size='xl'}} 2000w"
      sizes="100vw"
      alt="{{title}}"
      loading="eager"
      fetchpriority="high"
    />
  {{/if}}
  <div class="home-featured-overlay"></div>
  <div class="home-featured-content">
    {{#if primary_tag}}
      <div class="home-featured-breadcrumb">/ <a href="/{{#has tag="#en"}}en{{else}}{{#has tag="#pt"}}pt{{else}}{{#has tag="#fr"}}fr{{else}}{{#has tag="#zh"}}zh{{else}}{{#has tag="#ja"}}ja{{else}}{{#has tag="#ko"}}ko{{else}}{{#has tag="#tr"}}tr{{else}}es{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}{{/has}}/tag/{{primary_tag.slug}}/">{{primary_tag.name}}</a></div>
    {{/if}}
    <h1 class="home-featured-title">{{title}}</h1>
    <div class="home-featured-byline">
      <span class="home-featured-by">{{#has tag="#en"}}by{{else}}por{{/has}}</span>
      {{#primary_author}}<a href="{{url}}" class="home-featured-author">{{name}}</a>{{/primary_author}}
      <span class="home-featured-meta">· {{#has tag="#en"}}{{date published_at format="MMM D, YYYY"}}{{else}}{{date published_at format="D MMM YYYY"}}{{/has}} · {{reading_time minute="1 min" minutes="% min"}} {{#has tag="#en"}}read{{else}}lectura{{/has}}</span>
      <span id="translation-link" class="home-featured-translation"></span>
      <a href="#/share" class="home-featured-share" aria-label="{{#has tag="#en"}}Share{{else}}Compartir{{/has}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      </a>
    </div>
  </div>
</div>
