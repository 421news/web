{{!-- Itera todos los autores (soporta posts con co-autores).
     authorLabel/shareLabel vienen como params del wrapper (post-es/en/intl)
     porque {{#has tag}} no funciona dentro de {{#foreach authors}}
     (el contexto pasa a ser el autor, que no tiene tags) --}}
{{#foreach authors}}
<div class="post-author-card">
  {{#if profile_image}}
    <img
      src="{{img_url profile_image size="medium"}}"
      loading="lazy"
      alt="{{name}}"
      class="post-author-photo"
    />
  {{/if}}
  <div class="post-author-info">
    <div class="post-author-label">{{#if ../authorLabel}}{{../authorLabel}}{{else}}Escrito por{{/if}}</div>
    <a href="{{url}}" class="post-author-name">{{name}}</a>
    {{#if bio}}
      <p class="post-author-bio">{{bio}}</p>
    {{/if}}
    <div class="post-author-socials">
      {{#if twitter}}
        <a href="https://x.com/{{twitter}}" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2H21l-6.522 7.45L22 22h-6.873l-4.84-6.32L4.6 22H1.84l6.99-7.99L1 2h6.99l4.38 5.79L18.24 2z"/></svg>
        </a>
      {{/if}}
      {{#if facebook}}
        <a href="https://facebook.com/{{facebook}}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047v-2.66c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.971H15.83c-1.491 0-1.956.93-1.956 1.886v2.264h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
        </a>
      {{/if}}
      {{#if instagram}}
        <a href="https://instagram.com/{{instagram}}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.17.054 1.97.24 2.43.403a4.088 4.088 0 0 1 1.518.988 4.088 4.088 0 0 1 .988 1.518c.163.46.349 1.26.403 2.43.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.054 1.17-.24 1.97-.403 2.43a4.088 4.088 0 0 1-.988 1.518 4.088 4.088 0 0 1-1.518.988c-.46.163-1.26.349-2.43.403-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.17-.054-1.97-.24-2.43-.403a4.088 4.088 0 0 1-1.518-.988 4.088 4.088 0 0 1-.988-1.518c-.163-.46-.349-1.26-.403-2.43C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.054-1.17.24-1.97.403-2.43a4.088 4.088 0 0 1 .988-1.518 4.088 4.088 0 0 1 1.518-.988c.46-.163 1.26-.349 2.43-.403C8.416 2.175 8.796 2.163 12 2.163zM12 0C8.741 0 8.333.014 7.053.072 5.775.13 4.902.333 4.14.63a5.882 5.882 0 0 0-2.126 1.384A5.882 5.882 0 0 0 .63 4.14C.333 4.902.13 5.775.072 7.053.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.058 1.278.261 2.151.558 2.913a5.882 5.882 0 0 0 1.384 2.126A5.882 5.882 0 0 0 4.14 23.37c.762.297 1.635.5 2.913.558C8.333 23.986 8.741 24 12 24s3.667-.014 4.947-.072c1.278-.058 2.151-.261 2.913-.558a5.882 5.882 0 0 0 2.126-1.384 5.882 5.882 0 0 0 1.384-2.126c.297-.762.5-1.635.558-2.913C23.986 15.667 24 15.259 24 12s-.014-3.667-.072-4.947c-.058-1.278-.261-2.151-.558-2.913a5.882 5.882 0 0 0-1.384-2.126A5.882 5.882 0 0 0 19.86.63C19.098.333 18.225.13 16.947.072 15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
        </a>
      {{/if}}
      {{#if youtube}}
        <a href="https://youtube.com/{{youtube}}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.546 12 3.546 12 3.546s-7.505 0-9.377.504A3.016 3.016 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.504 9.376.504 9.376.504s7.505 0 9.377-.504a3.016 3.016 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      {{/if}}
      {{#if tiktok}}
        <a href="https://tiktok.com/{{tiktok}}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        </a>
      {{/if}}
      {{#if website}}
        <a href="{{website}}" target="_blank" rel="noopener noreferrer" aria-label="Website">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm6.918 6h-3.215a16.578 16.578 0 0 0-1.478-3.833A8.031 8.031 0 0 1 18.918 8zM12 4.04c.87 1.02 1.56 2.2 2.025 3.96H9.975C10.44 6.24 11.13 5.06 12 4.04zM4.26 14C4.1 13.36 4 12.69 4 12s.1-1.36.26-2h3.684a17.36 17.36 0 0 0 0 4H4.26zm.822 2h3.215a16.578 16.578 0 0 0 1.478 3.833A8.031 8.031 0 0 1 5.082 16zm3.215-8H5.082a8.031 8.031 0 0 1 4.693-3.833A16.578 16.578 0 0 0 8.297 8zM12 19.96c-.87-1.02-1.56-2.2-2.025-3.96h4.05C13.56 17.76 12.87 18.94 12 19.96zM14.34 14H9.66a15.29 15.29 0 0 1 0-4h4.68a15.29 15.29 0 0 1 0 4zm.885 5.833A16.578 16.578 0 0 0 16.703 16h3.215a8.031 8.031 0 0 1-4.693 3.833zM16.056 14a17.36 17.36 0 0 0 0-4h3.684c.16.64.26 1.31.26 2s-.1 1.36-.26 2h-3.684z"/></svg>
        </a>
      {{/if}}
      {{#if @last}}
      <a href="#/share" class="post-author-share" aria-label="{{#if ../shareLabel}}{{../shareLabel}}{{else}}Compartir{{/if}}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      </a>
      {{/if}}
    </div>
  </div>
</div>
{{/foreach}}
