
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://www.421.news/es/"
    }{{#if primary_tag}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{primary_tag.name}}",
      "item": "https://www.421.news/es/tag/{{primary_tag.slug}}/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{title}}"
    }{{else}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{title}}"
    }{{/if}}
  ]
}
</script>
<div class="page-wrapper">
    {{> "reading-progress-bar"}}
    {{> "general-styling"}}
    {{> "site-nav-es"}}
    <style>
        h2 {
        margin-bottom: 20px;
        }
        figcaption {
        margin-bottom: 20px;
        }
    </style>
    <main>
        {{#if featured}}
            {{> "featured-post-header"}}
        {{else}}
            {{> "post-header"}}
        {{/if}}
        <div class="global-container">
            <div class="pv-large">
                <div class="rich-text w-richtext">
                    {{content}}
                </div>
                <div class="pt-medium">
                    {{> post-author-box}}
                </div>
                <div class="post-comments" data-post-id="{{id}}" data-comments-enabled="paid"></div>
            </div>
        </div>

        {{#unless @member.paid}}
        <div class="global-container">
          <div class="post-cta post-cta-end">
            <p class="post-cta-text">&iquest;Te gust&oacute; lo que le&iacute;ste? 421 existe gracias a los Wizards. Sum&aacute;te y acced&eacute; a:</p>
            <ul class="post-cta-benefits">
              <li>La <strong>Revista 421 #<span data-revista-numero>14</span></strong> en PDF (y todos los n&uacute;meros anteriores)</li>
              <li>Comentar las notas</li>
              <li>El <strong>Concilio mensual de wizards</strong> (videollamada con Juan Ruocco)</li>
              <li>La <a href="https://mtg.421.news">app de Magic 421</a></li>
            </ul>
            <div class="post-cta-buttons"><a href="/es/suscribite/" class="post-cta-btn-primary">Hacete Wizard &rarr;</a></div>
          </div>
        </div>
        <script>
        (function(){
          var slots = document.querySelectorAll('[data-revista-numero]');
          if (!slots.length) return;
          fetch('/ghost/api/content/pages/slug/revista-421/?key=420da6f85b5cc903b347de9e33&formats=html', { headers: { 'Accept-Version': 'v5.0' } })
            .then(function(r){ return r.json(); })
            .then(function(d){
              var p = d.pages && d.pages[0];
              if (!p || !p.html) return;
              var doc = new DOMParser().parseFromString(p.html, 'text/html');
              var h2 = doc.querySelector('h2');
              if (!h2) return;
              var m = h2.textContent.trim().match(/#(\d+)/);
              if (!m) return;
              slots.forEach(function(el){ el.textContent = m[1]; });
            })
            .catch(function(){});
        })();
        </script>
        {{/unless}}

        <!-- RELATED POSTS -->
        <div class="preview-section" data-json="{{asset "data/related-posts.json"}}">
            <div class="global-container">
                <div class="pv-huge">
                    <div class="preview-section_flex-header">
                        <h2>Textos relacionados</h2>
                        {{#if primary_tag}}
                            <a href="/es/tag/{{primary_tag.slug}}" class="button w-button">Leer más</a>
                        {{/if}}
                    </div>
                    {{#get "posts"
                        include="tags,authors"
                        limit="4"
                        filter="id:-{{id}}+tag:{{primary_tag.slug}}+tag:hash-es+tag:-Wiki"
                        order="published_at desc"
                    }}
                        <div class="post-grid w-dyn-list">
                            <div role="list" class="post-cols w-dyn-items">
                                {{#foreach posts}}
                                    {{> "post-card"}}
                                {{/foreach}}
                            </div>
                        </div>
                    {{else}}
                        {{!-- Fallback: any recent ES post --}}
                        {{#get "posts"
                            include="tags,authors"
                            limit="4"
                            filter="id:-{{id}}+tag:hash-es+tag:-Wiki"
                            order="published_at desc"
                        }}
                            <div class="post-grid w-dyn-list">
                                <div role="list" class="post-cols w-dyn-items">
                                    {{#foreach posts}}
                                        {{> "post-card"}}
                                    {{/foreach}}
                                </div>
                            </div>
                        {{/get}}
                    {{/get}}
                </div>
            </div>
        </div>
    </main>
    <!-- FILE BROWSER NAVIGATION -->
    <div class="global-container pt-small pb-small">
      {{> "file-browser"}}
    </div>
    {{> "site-footer"}}
    {{> "subscribe-popup"}}
    <script src="{{asset "js/comments.js"}}" defer></script>
    <script src="{{asset "js/related-posts.js"}}" defer></script>
    {{#has tag="tutoriales"}}
    <script>
    (function() {
      var scripts = document.querySelectorAll('script[type="application/ld+json"]');
      for (var i = 0; i < scripts.length; i++) {
        try {
          var data = JSON.parse(scripts[i].textContent);
          if (data['@type'] === 'Article') {
            data['@type'] = ['Article', 'LearningResource'];
            data.learningResourceType = 'guide';
            data.educationalLevel = 'beginner';
            if (data.headline) data.teaches = data.headline;
            scripts[i].textContent = JSON.stringify(data);
            break;
          }
        } catch(e) {}
      }
    })();
    </script>
    {{/has}}
    {{!-- Mid-post CTA removed: B1 (post-cta-end) is the single unified upsell banner --}}
</div>