
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://www.421.news/es/"
    }{{#if primary_tag}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{primary_tag.name}}",
      "item": "https://www.421.news/es/tag/{{primary_tag.slug}}/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{title}}"
    }{{else}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{title}}"
    }{{/if}}
  ]
}
</script>
<div class="page-wrapper">
    {{> "reading-progress-bar"}}
    {{> "general-styling"}}
    {{> "site-nav-es"}}
    <style>
        h2 {
        margin-bottom: 20px;
        }
        figcaption {
        margin-bottom: 20px;
        }
    </style>
    <main>
        {{#if featured}}
            {{> "featured-post-header"}}
        {{else}}
            {{> "post-header"}}
        {{/if}}
        <div class="global-container">
            <div class="pv-large">
                <div class="rich-text w-richtext">
                    {{content}}
                </div>
                <div class="pt-medium">
                    {{> post-author-box}}
                </div>
            </div>
        </div>

        {{#unless @member.paid}}
        <div class="global-container">
          <div class="post-cta post-cta-end">
            <p class="post-cta-text">Te gust&oacute; lo que le&iacute;ste? Los Wizards hacen que 421 siga existiendo. Sumate y acced&eacute; a la revista digital, contenido exclusivo y m&aacute;s.</p>
            <div class="post-cta-buttons"><a href="/es/suscribite/" class="post-cta-btn-primary">Hacete Wizard &rarr;</a></div>
          </div>
        </div>
        {{/unless}}

        <!-- RELATED POSTS -->
        <div class="preview-section" data-json="{{asset "data/related-posts.json"}}">
            <div class="global-container">
                <div class="pv-huge">
                    <div class="preview-section_flex-header">
                        <h2>Textos relacionados</h2>
                        {{#if primary_tag}}
                            <a href="/es/tag/{{primary_tag.slug}}" class="button w-button">Leer más</a>
                        {{/if}}
                    </div>
                    {{#get "posts"
                        include="tags,authors"
                        limit="4"
                        filter="id:-{{id}}+tag:{{primary_tag.slug}}+tag:hash-es+tag:-Wiki"
                        order="published_at desc"
                    }}
                        <div class="post-grid w-dyn-list">
                            <div role="list" class="post-cols w-dyn-items">
                                {{#foreach posts}}
                                    {{> "post-card"}}
                                {{/foreach}}
                            </div>
                        </div>
                    {{else}}
                        {{!-- Fallback: any recent ES post --}}
                        {{#get "posts"
                            include="tags,authors"
                            limit="4"
                            filter="id:-{{id}}+tag:hash-es+tag:-Wiki"
                            order="published_at desc"
                        }}
                            <div class="post-grid w-dyn-list">
                                <div role="list" class="post-cols w-dyn-items">
                                    {{#foreach posts}}
                                        {{> "post-card"}}
                                    {{/foreach}}
                                </div>
                            </div>
                        {{/get}}
                    {{/get}}
                </div>
            </div>
        </div>
    </main>
    <!-- FILE BROWSER NAVIGATION -->
    <div class="global-container pt-small pb-small">
      {{> "file-browser"}}
    </div>
    {{> "site-footer"}}
    {{> "subscribe-popup"}}
    <script src="{{asset "js/related-posts.js"}}" defer></script>
    {{#has tag="tutoriales"}}
    <script>
    (function() {
      var scripts = document.querySelectorAll('script[type="application/ld+json"]');
      for (var i = 0; i < scripts.length; i++) {
        try {
          var data = JSON.parse(scripts[i].textContent);
          if (data['@type'] === 'Article') {
            data['@type'] = ['Article', 'LearningResource'];
            data.learningResourceType = 'guide';
            data.educationalLevel = 'beginner';
            if (data.headline) data.teaches = data.headline;
            scripts[i].textContent = JSON.stringify(data);
            break;
          }
        } catch(e) {}
      }
    })();
    </script>
    {{/has}}
    {{#unless @member.paid}}
    <script>
    (function() {
      var KEY = 'mid_cta_dismissed';
      var d = localStorage.getItem(KEY);
      if (d && (Date.now() - parseInt(d, 10)) < 3 * 86400000) return;
      var hh = document.querySelectorAll('.rich-text h2');
      if (hh.length < 3) return;
      var el = document.createElement('div');
      el.className = 'post-cta';
      el.innerHTML = '<p class="post-cta-text">Si lleg\u00e1s hasta ac\u00e1, 421 es para vos. Ensayos, gu\u00edas y an\u00e1lisis que no vas a encontrar en otro lado \u2014 y los Wizards son quienes lo hacen posible.</p><div class="post-cta-buttons"><a href="/es/suscribite/" class="post-cta-btn-primary">Sumate a 421 \u2192</a></div><button class="mid-cta-dismiss">Ahora no</button>';
      el.querySelector('.mid-cta-dismiss').onclick = function() { el.remove(); localStorage.setItem(KEY, Date.now()); };
      hh[2].parentNode.insertBefore(el, hh[2]);
    })();
    </script>
    {{/unless}}
</div>