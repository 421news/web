<div class="preview-section">
    <div class="global-container">
        <div class="pv-huge">
            <div class="last-posts-header">
                <h2 class="last-posts-title"><a href="/en/last-posts/">Last posts</a></h2>
                <a href="/en/last-posts/" class="last-posts-more">View all</a>
            </div>
            <div class="last-posts-section">
                {{#get "posts"
                    include="tags,authors"
                    filter="tag:'hash-en'+tag:-'hash-satelite'"
                    limit="20"
                    order="published_at desc"
                    as |articles|
                }}
                    {{#if articles}}
                        {{#foreach articles}}
                            {{> "post-card"}}
                        {{/foreach}}
                    {{/if}}
                {{/get}}
            </div>
            <button
                class="btn-load-more"
                id="load-more-home"
            >
                Load more
            </button>
        {{!-- <div class="post-cols w-dyn-list">
            {{> "tps_alt-en" tag="Culture" slug="culture"}}
            {{> "tps_alt-en" tag="Tech" slug="tech"}}
            {{> "tps_alt-en" tag="Games" slug="games"}}
            {{> "tps_alt-en" tag="Real life" slug="real-life"}}
        </div> --}}
        </div>
    </div>
</div>