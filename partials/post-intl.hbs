
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{url absolute=true}}"
    }{{#if primary_tag}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{primary_tag.name}}",
      "item": "https://www.421.news{{#primary_tag}}{{url}}{{/primary_tag}}"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{title}}"
    }{{else}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{title}}"
    }{{/if}}
  ]
}
</script>
<div class="page-wrapper">
    {{> "reading-progress-bar"}}
    {{> "general-styling"}}
    {{> "site-nav-intl" lang=lang}}
    <style>
        h2 {
        margin-bottom: 20px;
        }
        figcaption {
        margin-bottom: 20px;
        }
    </style>
    <main>
        {{#if featured}}
            {{> "featured-post-header"}}
        {{else}}
            {{> "post-header"}}
        {{/if}}
        <div class="global-container">
            <div class="pv-large">
            <div class="rich-text w-richtext">{{content}}</div>
            <div class="pt-medium">
                {{> post-author-box}}
            </div>
            </div>
        </div>

        <!-- RELATED POSTS (fetched client-side to filter by language) -->
        <div class="preview-section">
            <div class="global-container">
                <div class="pv-huge">
                    <div class="preview-section_flex-header">
                        <h2>Related posts</h2>
                    </div>
                    <div id="intl-related-posts" class="post-grid w-dyn-list">
                        <div role="list" class="post-cols w-dyn-items"></div>
                    </div>
                </div>
            </div>
        </div>
        <script>
        (function() {
          var m = window.location.pathname.match(/^\/([a-z]{2})\//);
          if (!m) return;
          var lang = m[1];
          var slug = window.location.pathname.split('/').filter(Boolean).pop();
          var filter = 'slug:-' + slug + '+tag:hash-' + lang;
          fetch('/ghost/api/content/posts/?key=420da6f85b5cc903b347de9e33&include=tags,authors&limit=4&filter=' + encodeURIComponent(filter) + '&order=published_at%20desc', { headers: { 'Accept-Version': 'v5.0' } })
            .then(function(r) { return r.json(); })
            .then(function(d) {
              var posts = d.posts || [];
              var container = document.querySelector('#intl-related-posts .w-dyn-items');
              if (!container || !posts.length) return;
              var html = '';
              posts.forEach(function(p) { html += window.renderCard(p); });
              container.innerHTML = html;
            }).catch(function() {});
        })();
        </script>
    </main>
    {{> "site-footer"}}
    <script src="{{asset "js/related-posts.js"}}" defer></script>
</div>
