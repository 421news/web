<div class="preview-section">
    <div class="global-container">
        <div class="pv-huge">
            <div class="preview-section_flex-header pb-small">
                <h2 id="last-posts-title">Last posts →</h2>
            </div>
            <div class="last-posts-section">
            </div>
            <button
                class="button"
                id="load-more-home"
                style="display: block; margin: auto; margin-top: 50px;"
            >
                Load more
            </button>
        </div>
    </div>
</div>
<script>
(function() {
  var API_KEY = '420da6f85b5cc903b347de9e33';
  var lang = window.location.pathname.match(/^\/([a-z]{2})\//);
  lang = lang ? lang[1] : 'en';

  var labels = {
    pt: { title: 'Últimos posts →', btn: 'Carregar mais' },
    fr: { title: 'Derniers articles →', btn: 'Charger plus' },
    zh: { title: '最新文章 →', btn: '加载更多' },
    ja: { title: '最新記事 →', btn: 'もっと読む' },
    ko: { title: '최신 글 →', btn: '더 보기' },
    tr: { title: 'Son yazılar →', btn: 'Daha fazla' }
  };

  var titleEl = document.getElementById('last-posts-title');
  var btnEl = document.getElementById('load-more-home');
  if (labels[lang]) {
    if (titleEl) titleEl.textContent = labels[lang].title;
    if (btnEl) btnEl.textContent = labels[lang].btn;
  }

  var feed = document.querySelector('.last-posts-section');
  var filter = 'tag:hash-' + lang + '+tag:-hash-satelite';

  function buildURL(page) {
    return '/ghost/api/content/posts/?key=' + API_KEY +
      '&page=' + page + '&limit=20&include=authors,tags&order=published_at%20desc' +
      '&filter=' + encodeURIComponent(filter);
  }

  var nextPage = 1;
  var loading = false;

  function loadPosts(page, append) {
    if (loading) return;
    loading = true;
    btnEl.disabled = true;
    btnEl.textContent = 'Loading...';

    fetch(buildURL(page), { headers: { 'Accept-Version': 'v5.0' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var posts = data.posts || [];
        var html = posts.map(window.renderCard).join('');
        if (append) {
          feed.insertAdjacentHTML('beforeend', html);
        } else {
          feed.innerHTML = html;
        }
        var pag = data.meta && data.meta.pagination;
        nextPage = pag ? pag.next : null;
        if (nextPage) {
          btnEl.style.display = 'block';
          btnEl.disabled = false;
          btnEl.textContent = (labels[lang] || {}).btn || 'Load more';
        } else {
          btnEl.style.display = posts.length ? 'none' : 'block';
          if (!posts.length) btnEl.textContent = 'No posts';
          btnEl.disabled = true;
        }
      })
      .catch(function() { btnEl.disabled = false; })
      .then(function() { loading = false; });
  }

  btnEl.addEventListener('click', function() {
    if (nextPage) loadPosts(nextPage, true);
  });

  loadPosts(1, false);
})();
</script>
