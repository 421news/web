
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://www.421.news/en/"
    }{{#if primary_tag}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{primary_tag.name}}",
      "item": "https://www.421.news/en/tag/{{primary_tag.slug}}/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{title}}"
    }{{else}},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{title}}"
    }{{/if}}
  ]
}
</script>
<div class="page-wrapper">
    {{> "reading-progress-bar"}}
    {{> "general-styling"}}
    {{> "site-nav-en"}}
    <style>
        h2 {
        margin-bottom: 20px;
        }
        figcaption {
        margin-bottom: 20px;
        }
    </style>
    <main>
        {{#if featured}}
            {{> "featured-post-header" lang="en"}}
        {{else}}
            {{> "post-header" lang="en"}}
        {{/if}}
        <div class="global-container">
            <div class="pv-large">
            <div class="rich-text w-richtext">{{content}}</div>
            <div class="pt-medium">
                {{> post-author-box}}
            </div>
                <div class="post-comments" data-post-id="{{id}}" data-comments-enabled="paid"></div>
            </div>
        </div>

        {{#unless @member.paid}}
        <div class="global-container">
          <div class="post-cta post-cta-end">
            <p class="post-cta-text">Enjoyed this? 421 runs on Wizards. Join and unlock <a href="/es/revista-421/">Revista 421 #<span data-revista-numero>14</span></a> in PDF, commenting on articles, the <a href="/author/juan-ruocco/">Monthly Wizard Council</a> (video call with Juan Ruocco) and the <a href="https://mtg.421.news">Magic 421 app</a>.</p>
            <div class="post-cta-buttons"><a href="/es/revista-421/" class="post-cta-btn-primary">Read the magazine &rarr;</a></div>
          </div>
        </div>
        <script>
        (function(){
          var slots = document.querySelectorAll('[data-revista-numero]');
          if (!slots.length) return;
          fetch('/ghost/api/content/pages/slug/revista-421/?key=420da6f85b5cc903b347de9e33&formats=html', { headers: { 'Accept-Version': 'v5.0' } })
            .then(function(r){ return r.json(); })
            .then(function(d){
              var p = d.pages && d.pages[0];
              if (!p || !p.html) return;
              var doc = new DOMParser().parseFromString(p.html, 'text/html');
              var h2 = doc.querySelector('h2');
              if (!h2) return;
              var m = h2.textContent.trim().match(/#(\d+)/);
              if (!m) return;
              slots.forEach(function(el){ el.textContent = m[1]; });
            })
            .catch(function(){});
        })();
        </script>
        {{/unless}}

        <!-- RELATED POSTS -->
        <div class="preview-section" data-json="{{asset "data/related-posts.json"}}">
            <div class="global-container">
                <div class="pv-huge">
                    <div class="preview-section_flex-header">
                        <h2>Related posts</h2>
                        {{#if primary_tag}}
                            <a href="/en/tag/{{primary_tag.slug}}" class="button w-button">Read more</a>
                        {{/if}}
                    </div>
                    {{#get "posts"
                        include="tags,authors"
                        limit="4"
                        filter="id:-{{id}}+tag:{{primary_tag.slug}}+tag:hash-en+tag:-Wiki"
                        order="published_at desc"
                    }}
                        <div class="post-grid w-dyn-list">
                            <div role="list" class="post-cols w-dyn-items">
                                {{#foreach posts}}
                                    {{> "post-card"}}
                                {{/foreach}}
                            </div>
                        </div>
                    {{else}}
                        {{!-- Fallback: any recent EN post --}}
                        {{#get "posts"
                            include="tags,authors"
                            limit="4"
                            filter="id:-{{id}}+tag:hash-en+tag:-Wiki"
                            order="published_at desc"
                        }}
                            <div class="post-grid w-dyn-list">
                                <div role="list" class="post-cols w-dyn-items">
                                    {{#foreach posts}}
                                        {{> "post-card"}}
                                    {{/foreach}}
                                </div>
                            </div>
                        {{/get}}
                    {{/get}}
                </div>
            </div>
        </div>
    </main>
    <!-- FILE BROWSER NAVIGATION -->
    <div class="global-container pt-small pb-small">
      {{> "file-browser-en"}}
    </div>
    {{> "site-footer" lang="en"}}
    {{> "subscribe-popup"}}
    <script src="{{asset "js/comments.js"}}" defer></script>
    <script src="{{asset "js/related-posts.js"}}" defer></script>
    {{#has tag="tutoriales,tutorials"}}
    <script>
    (function() {
      var scripts = document.querySelectorAll('script[type="application/ld+json"]');
      for (var i = 0; i < scripts.length; i++) {
        try {
          var data = JSON.parse(scripts[i].textContent);
          if (data['@type'] === 'Article') {
            data['@type'] = ['Article', 'LearningResource'];
            data.learningResourceType = 'guide';
            data.educationalLevel = 'beginner';
            if (data.headline) data.teaches = data.headline;
            scripts[i].textContent = JSON.stringify(data);
            break;
          }
        } catch(e) {}
      }
    })();
    </script>
    {{/has}}
    {{!-- Mid-post CTA removed: B1 (post-cta-end) is the single unified upsell banner --}}
</div>