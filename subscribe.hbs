{{!< default}}

<script>
  document.title = 'Subscribe to 421 | 421.news';
  (function() {
    var title = 'Subscribe to 421 | 421.news';
    var desc = '421 is an intellectual orientation outlet. Subscribe for full access to all content.';
    var img = 'https://www.421.news/content/images/2026/01/10_diciembre.jpg';
    var url = 'https://www.421.news/en/subscribe/';
    function setMeta(attr, key, val) {
      var el = document.querySelector('meta[' + attr + '="' + key + '"]');
      if (el) { el.content = val; }
      else { var m = document.createElement('meta'); m.setAttribute(attr, key); m.content = val; document.head.appendChild(m); }
    }
    setMeta('name', 'description', desc);
    setMeta('property', 'og:title', title);
    setMeta('property', 'og:description', desc);
    setMeta('property', 'og:image', img);
    setMeta('property', 'og:url', url);
    setMeta('property', 'og:type', 'website');
    setMeta('name', 'twitter:card', 'summary_large_image');
    setMeta('name', 'twitter:title', title);
    setMeta('name', 'twitter:description', desc);
    setMeta('name', 'twitter:image', img);
  })();
</script>

    <link href="{{asset "css/suscribite.css"}}" rel="stylesheet" type="text/css">
    <div class="page-wrapper">
      {{> "general-styling"}}
      {{> "site-nav-en"}}

      <div class="sub-page">
        <div class="sub-container">

          <!-- ===== SECTION 1: HERO + PLAN ===== -->
          <div id="sub-section-plan">

            <div class="sub-hero">
              <span class="sub-hero-eyebrow">✨ Become a Wizard</span>
              <h1 class="sub-hero-title">Read <span class="sub-hero-accent">Revista 421 before anyone else</span> and back the project</h1>
              <p class="sub-hero-subtitle">Every new issue reaches Wizards <strong>one month before</strong> the public. Plus commenting on articles, the Magic app and the Monthly Council with Juan Ruocco.</p>
              <div class="sub-hero-proof">242 wizards · 5,379 readers</div>
            </div>
            <hr class="sub-gradient-divider">

            <div class="tier-grid">

              <!-- FREE TIER -->
              <div class="tier">
                <h2 class="tier-name">Free</h2>
                <p class="tier-tagline">To start reading 421</p>
                <div class="tier-price"><span class="tier-price-amount">$0</span></div>
                <ul class="tier-benefits">
                  <li>Weekly newsletter with the best of 421</li>
                  <li>Download of <strong>released</strong> magazines (back issues)</li>
                </ul>
                <button class="btn-outline" id="btn-free">Sign up for free →</button>
                <p class="tier-fine">No card · Cancel anytime</p>
              </div>

              <!-- PAID TIER -->
              <div class="tier featured" id="sub-plan-card">
                <span class="tier-badge">Most popular</span>
                <h2 class="tier-name">Wizard</h2>
                <p class="tier-tagline">Full access + back the project</p>

                <div class="plan-toggle">
                  <button class="plan-toggle-btn active" id="toggle-monthly">Monthly</button>
                  <button class="plan-toggle-btn" id="toggle-yearly">
                    Annual
                    <span class="toggle-badge">-17%</span>
                  </button>
                </div>

                <div id="plan-price" class="tier-price">
                  <span class="tier-price-amount" id="price-amount">...</span>
                  <span class="tier-price-period" id="price-period">USD / month</span>
                  <div class="plan-price-detail" id="price-detail"></div>
                </div>

                <ul class="tier-benefits">
                  <li class="tier-benefit-featured">📕 Read <strong>Revista 421</strong> in PDF <strong>one month before</strong> public release</li>
                  <li>Comment and join discussions on every article</li>
                  <li><strong>Monthly Council</strong>: video call with <a href="/author/juan-ruocco/">Juan Ruocco</a> and other wizards</li>
                  <li>Access to the <a href="https://mtg.421.news">Magic 421 app</a></li>
                </ul>

                <button class="btn-gradient" id="btn-suscribirme">Become a Wizard →</button>
                <p class="tier-fine">Pay with international card (Stripe, USD)</p>
              </div>

            </div>

            <!-- ===== FAQ ===== -->
            <section class="sub-faq">
              <h2>FAQ</h2>
              <details class="sub-faq-item">
                <summary>What exactly is "early access" to the magazine?</summary>
                <p>Each new issue of Revista 421 is released first to Wizards only, as a PDF. One month later it's released to the rest of the public.</p>
              </details>
              <details class="sub-faq-item">
                <summary>How do I cancel?</summary>
                <p>From your account, anytime. No commitment, no questions. You keep access until the end of the paid period.</p>
              </details>
              <details class="sub-faq-item">
                <summary>What about old issues of the magazine?</summary>
                <p>They remain available to everyone (free). Only the <strong>latest issue</strong> is reserved for Wizards during its first month.</p>
              </details>
              <details class="sub-faq-item">
                <summary>What's the Monthly Council?</summary>
                <p>A roughly 1-hour video call with Juan Ruocco and other Wizards. Open discussion, editorial proposals, debates. Announced in advance via newsletter.</p>
              </details>
            </section>
          </div>


          <!-- EN version: Stripe only, no MercadoPago -->

        </div>
      </div>

      {{> "site-footer" lang="en"}}
    </div>

    <script defer>
      document.addEventListener('DOMContentLoaded', function() {
        var currentCadence = 'monthly';
        var tierData = null;

        fetch('/ghost/api/content/tiers/?key=420da6f85b5cc903b347de9e33')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var tiers = data.tiers || [];
            for (var i = 0; i < tiers.length; i++) {
              if (tiers[i].type === 'paid' && tiers[i].active) {
                tierData = tiers[i];
                break;
              }
            }
            if (tierData) updatePriceDisplay();
          });

        function formatPrice(cents) {
          var dollars = cents / 100;
          return '$' + (dollars % 1 === 0 ? dollars : dollars.toFixed(2));
        }

        function updatePriceDisplay() {
          if (!tierData) return;
          var amountEl = document.getElementById('price-amount');
          var periodEl = document.getElementById('price-period');
          var detailEl = document.getElementById('price-detail');

          if (currentCadence === 'yearly') {
            amountEl.textContent = formatPrice(tierData.yearly_price);
            periodEl.textContent = 'USD / year';
            var monthlyTotal = tierData.monthly_price * 12;
            detailEl.innerHTML = '<span class="striked">' + formatPrice(monthlyTotal) + '</span> \u2014 save 2 months';
          } else {
            amountEl.textContent = formatPrice(tierData.monthly_price);
            periodEl.textContent = 'USD / month';
            detailEl.textContent = 'No commitment, cancel anytime';
          }
        }

        var toggleM = document.getElementById('toggle-monthly');
        var toggleY = document.getElementById('toggle-yearly');

        toggleM.addEventListener('click', function() {
          currentCadence = 'monthly';
          toggleM.classList.add('active');
          toggleY.classList.remove('active');
          updatePriceDisplay();
        });

        toggleY.addEventListener('click', function() {
          currentCadence = 'yearly';
          toggleY.classList.add('active');
          toggleM.classList.remove('active');
          updatePriceDisplay();
        });

        document.getElementById('btn-suscribirme').addEventListener('click', function() {
          if (!tierData) return;
          if (typeof gtag === 'function') gtag('event', 'begin_checkout', {
            event_category: 'subscription',
            event_label: 'wizard_' + currentCadence + '_en',
            value: currentCadence === 'yearly' ? (tierData.yearly_price/100) : (tierData.monthly_price/100),
            currency: 'USD',
            items: [{ item_id: tierData.id, item_name: 'Wizard ' + currentCadence }]
          });
          window.location.hash = '#/portal/signup/' + tierData.id + '/' + currentCadence;
        });

        document.getElementById('btn-free').addEventListener('click', function() {
          if (typeof gtag === 'function') gtag('event', 'sign_up_intent', {
            event_category: 'subscription',
            event_label: 'free_newsletter_en'
          });
          window.location.hash = '#/portal/signup/free';
        });
      });
    </script>
