{{!< default}}

<meta name="robots" content="noindex, nofollow">

<script>
  // Track signup completion (fired when user lands on /gracias/ after Ghost Portal signup)
  (function(){
    if (typeof gtag !== 'function') return;
    var params = new URLSearchParams(window.location.search);
    var isPaid = params.get('type') === 'paid' || /portal\/checkout/.test(document.referrer || '');
    gtag('event', isPaid ? 'purchase' : 'sign_up', {
      event_category: 'subscription',
      event_label: isPaid ? 'completed_paid' : 'completed_free',
      transaction_id: params.get('session_id') || ('signup_' + Date.now())
    });
  })();
</script>

    <link href="{{asset "css/suscribite.css"}}" rel="stylesheet" type="text/css">
    <div class="page-wrapper">
      {{> "general-styling"}}
      {{> "site-nav-es"}}

      <div class="subscription-section">
        <main class="global-container" style="margin-bottom: 50px;">
          <div class="pv-huge">
            <h2
              class="title"
              style="
                text-align: center;
                margin-top: 50px;
              "
            >
              ¡Gracias por suscribirte!
            </h2>
          </div>
        </main>
      </div>

      <!-- FILE BROWSER NAVIGATION -->
      <div class="global-container pt-small pb-small">
        {{> "file-browser"}}
      </div>
      {{> "site-footer"}}
    </div>
