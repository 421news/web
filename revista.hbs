{{!< default}}

<script>
  document.title = 'Revista 421 | 421.news';
  (function() {
    var title = 'Revista 421 | 421.news';
    var desc = 'La revista digital de 421. Todos los números disponibles para descargar gratis.';
    var img = 'https://www.421.news/content/images/2026/01/10_diciembre.jpg';
    var url = 'https://www.421.news/es/revista-421/';
    function setMeta(attr, key, val) {
      var el = document.querySelector('meta[' + attr + '="' + key + '"]');
      if (el) { el.content = val; }
      else { var m = document.createElement('meta'); m.setAttribute(attr, key); m.content = val; document.head.appendChild(m); }
    }
    setMeta('name', 'description', desc);
    setMeta('property', 'og:title', title);
    setMeta('property', 'og:description', desc);
    setMeta('property', 'og:image', img);
    setMeta('property', 'og:url', url);
    setMeta('property', 'og:type', 'website');
    setMeta('name', 'twitter:card', 'summary_large_image');
    setMeta('name', 'twitter:title', title);
    setMeta('name', 'twitter:description', desc);
    setMeta('name', 'twitter:image', img);
  })();
</script>

<div class="page-wrapper">
  {{> "general-styling"}}
  {{> "site-nav-es"}}

  {{!-- Wizards early-access announcement bar (visible to non-paid members only) --}}
  {{#unless @member.paid}}
  <div class="revista-wizard-announce">
    <div class="revista-wizard-announce-inner">
      <span>📕 Los <strong>Wizards</strong> leen cada nuevo n&uacute;mero <strong>un mes antes</strong> que el p&uacute;blico.</span>
      <a href="/es/suscribite/" onclick="if(typeof gtag==='function')gtag('event','revista_wizard_cta_click',{event_category:'engagement',event_label:'revista_page'});">Hacete Wizard &rarr;</a>
    </div>
  </div>
  {{/unless}}

  {{> "section-hero"
      eyebrow="421 · revista digital"
      title="Revista 421"
      tesis="Los números de la revista digital de 421, donde compilamos las notas destacadas del sitio e invitamos a diseñadores, fotógrafos e ilustradores."}}

  <div class="revista-page">
    <div class="global-container">

      <!-- Revista container: JS will populate this -->
      <div id="revista-container"></div>

    </div>

    <!-- File Browser -->
    <div class="global-container" style="padding: 3rem 0;">
      {{> "file-browser"}}
    </div>
  </div>

  {{> "site-footer"}}
</div>

<script src="{{asset "js/revista.js"}}" defer></script>
