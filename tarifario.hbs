<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow, noarchive">
<meta name="googlebot" content="noindex, nofollow">
<title>421 · Tarifario Comercial 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --negro:#121212;
    --negro-2:#1b1b1b;
    --crema:#eae6e1;
    --amarillo:#fcd221;
    --verde:#17a583;
    --gradient:linear-gradient(280deg,var(--verde),var(--amarillo));
    --dim:rgba(234,230,225,.6);
    --line:rgba(234,230,225,.14);
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    background:var(--negro);
    color:var(--crema);
    font-family:'Inter',system-ui,sans-serif;
    -webkit-font-smoothing:antialiased;
  }
  h1,h2,h3,.display{font-family:'Space Grotesk',sans-serif;letter-spacing:-.02em;line-height:1.02}
  a{color:inherit}

  .slide{
    min-height:100vh;
    width:100%;
    padding:6vh 7vw;
    display:flex;
    flex-direction:column;
    justify-content:center;
    position:relative;
    border-bottom:1px solid var(--line);
    overflow:hidden;
  }
  .eyebrow{
    font-family:'Space Grotesk',sans-serif;
    text-transform:uppercase;
    letter-spacing:.18em;
    font-size:.72rem;
    font-weight:600;
    color:var(--amarillo);
    margin-bottom:1.4rem;
  }
  .slide-num{
    position:absolute;top:5vh;right:7vw;
    font-family:'Space Grotesk',sans-serif;
    font-size:.78rem;color:var(--dim);letter-spacing:.1em;
  }
  .gradient-text{
    background:var(--gradient);
    -webkit-background-clip:text;background-clip:text;
    -webkit-text-fill-color:transparent;
  }

  /* LANGUAGE SWITCH */
  .lang-switch{
    position:fixed;bottom:1.4rem;right:1.4rem;z-index:999;
    display:flex;gap:2px;padding:3px;border-radius:999px;
    background:rgba(27,27,27,.82);border:1px solid var(--line);
    backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    box-shadow:0 6px 24px rgba(0,0,0,.35);
  }
  .lang-switch button{
    font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.78rem;
    letter-spacing:.06em;color:var(--dim);background:none;border:none;cursor:pointer;
    padding:.45rem .9rem;border-radius:999px;transition:all .18s;
  }
  .lang-switch button:hover{color:var(--crema)}
  .lang-switch button.active{background:var(--gradient);color:var(--negro)}

  /* DOWNLOAD PDF BUTTON */
  .dl-btn{
    position:fixed;bottom:1.4rem;left:1.4rem;z-index:999;
    font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.78rem;
    letter-spacing:.05em;text-transform:uppercase;cursor:pointer;
    padding:.6rem 1.2rem;border-radius:999px;
    border:1.5px solid var(--amarillo);background:rgba(27,27,27,.82);color:var(--amarillo);
    backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
    box-shadow:0 6px 24px rgba(0,0,0,.35);transition:all .18s;
  }
  .dl-btn:hover{background:var(--amarillo);color:var(--negro)}

  .logo-link{display:inline-block;line-height:0;transition:opacity .18s}
  .logo-link:hover{opacity:.82}

  /* COVER */
  .cover{justify-content:space-between;background:
    radial-gradient(circle at 80% 15%,rgba(23,165,131,.18),transparent 45%),
    radial-gradient(circle at 15% 90%,rgba(252,210,33,.12),transparent 45%),var(--negro);}
  .cover-top{display:flex;justify-content:space-between;align-items:flex-start}
  .brand-logo{height:88px;width:auto;display:block}
  .brand-logo--sm{height:54px;width:auto;display:block}
  .cover-mid h1{font-size:clamp(3rem,8vw,7rem);font-weight:700}
  .cover-mid p{font-size:clamp(1.1rem,2vw,1.5rem);color:var(--dim);max-width:42ch;margin-top:1.6rem;line-height:1.4}
  .cover-bottom{display:flex;justify-content:space-between;align-items:flex-end;color:var(--dim);font-size:.9rem}
  .vig-pill{display:inline-block;background:rgba(27,27,27,.7);border:1px solid var(--line);border-radius:999px;padding:.45rem 1.1rem;font-family:'Space Grotesk',sans-serif;font-size:.85rem;color:var(--crema);margin-top:1.8rem}

  /* STAT GRID */
  .stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.6rem;margin-top:1rem}
  .stat{border-top:2px solid var(--amarillo);padding-top:1.1rem}
  .stat .num{font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(2.4rem,5vw,4rem);line-height:.95}
  .stat .lbl{color:var(--dim);font-size:.92rem;margin-top:.6rem;line-height:1.35}
  .stat.green{border-color:var(--verde)}

  h2.title{font-size:clamp(2rem,4.5vw,3.4rem);font-weight:700;margin-bottom:.4rem}
  .subtitle{color:var(--dim);font-size:1.05rem;max-width:64ch;margin-bottom:2.2rem;line-height:1.45}

  /* RATE TABLES */
  .rate-grid{display:grid;grid-template-columns:1fr 1fr;gap:2.4rem 4vw;margin-top:.6rem}
  .rate-grid.one{grid-template-columns:1fr;max-width:760px}
  .rate-cat{break-inside:avoid}
  .rate-cat h3{
    font-family:'Space Grotesk',sans-serif;text-transform:uppercase;letter-spacing:.12em;
    font-size:.82rem;font-weight:600;color:var(--amarillo);margin-bottom:.2rem;
    display:flex;align-items:baseline;gap:.6rem;
  }
  .rate-cat h3 .meta{font-family:'Inter',sans-serif;text-transform:none;letter-spacing:0;font-weight:400;font-size:.72rem;color:var(--dim)}
  .rate{width:100%;border-collapse:collapse}
  .rate tr{border-bottom:1px solid var(--line)}
  .rate td{padding:.7rem 0;vertical-align:top}
  .rate .it{font-weight:600;font-size:.95rem;padding-right:1rem}
  .rate .it .d{display:block;color:var(--dim);font-weight:400;font-size:.8rem;margin-top:.2rem;line-height:1.35}
  .rate .pr{text-align:right;white-space:nowrap;padding-left:1.4rem}
  .rate .pr .usd{font-family:'Space Grotesk',sans-serif;font-weight:700;color:var(--amarillo);font-size:1.05rem}
  .rate .pr .unit{display:block;color:var(--dim);font-size:.68rem;text-transform:uppercase;letter-spacing:.08em;margin-top:.15rem;font-family:'Space Grotesk',sans-serif}
  .rate .pr .ars{display:block;color:var(--dim);font-size:.72rem;margin-top:.25rem}
  .rate .pr .pre{color:var(--dim);font-size:.8rem;margin-right:.25rem}
  .rate .pr.quote-cell{vertical-align:middle;text-align:right}
  .rate .pr .quote{
    display:inline-block;border:1.5px solid var(--amarillo);border-radius:999px;
    padding:.5rem 1.2rem;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:.8rem;
    text-transform:uppercase;letter-spacing:.05em;color:var(--amarillo);text-decoration:none;
    white-space:nowrap;transition:all .18s;
  }
  .rate .pr .quote:hover{background:var(--amarillo);color:var(--negro)}

  /* TEAM BADGE (shown only to verified team members) */
  .team-badge{
    display:none;position:fixed;top:1.2rem;left:1.2rem;z-index:999;
    font-family:'Space Grotesk',sans-serif;font-size:.7rem;letter-spacing:.05em;text-transform:uppercase;
    color:var(--verde);background:rgba(27,27,27,.82);border:1px solid var(--line);border-radius:999px;
    padding:.4rem .9rem;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
  }
  body.team .team-badge{display:block}

  .note{color:var(--dim);font-size:.78rem;margin-top:auto;padding-top:2rem;line-height:1.5}
  .conds{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem 3vw;margin-top:1rem;list-style:none}
  .conds li{display:flex;gap:.7rem;font-size:.9rem;color:var(--crema);line-height:1.4;border-top:1px solid var(--line);padding-top:.9rem}
  .conds li b{color:var(--amarillo);font-family:'Space Grotesk',sans-serif;font-weight:600;flex:none}

  .cta-line{font-size:clamp(1.3rem,3vw,2.2rem);font-weight:600;line-height:1.25;max-width:26ch;margin-bottom:1.6rem}
  .cta-line .gradient-text{font-weight:700}
  .contact-row{display:flex;gap:2.4rem;flex-wrap:wrap;font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:1.1rem;margin-top:.4rem}
  .contact-row a{text-decoration:none;color:var(--crema);transition:color .18s}
  .contact-row a:hover{color:var(--amarillo)}

  @media (max-width:760px){
    .stat-grid{grid-template-columns:1fr 1fr}
    .rate-grid{grid-template-columns:1fr}
    .conds{grid-template-columns:1fr}
    .lang-switch{bottom:1rem;right:1rem}
    .dl-btn{bottom:1rem;left:1rem}
  }

  /* PRINT → slides as landscape PDF pages */
  @page{size:1280px 720px;margin:0}
  @media print{
    body{background:var(--negro)}
    .slide{min-height:720px;height:auto;page-break-after:always;border:none}
    .lang-switch,.dl-btn,.team-badge{display:none}
  }
</style>
</head>
<body>

<!-- LANGUAGE SWITCH -->
<div class="lang-switch" role="group" aria-label="Idioma / Language">
  <button type="button" data-setlang="es" class="active">ES</button>
  <button type="button" data-setlang="en">EN</button>
</div>
<button class="dl-btn" type="button" onclick="window.print()" data-i18n="dl">Descargar PDF</button>
<div class="team-badge" data-i18n="team_badge">✓ Vista equipo · con precios</div>

