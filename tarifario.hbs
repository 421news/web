  function fmtN(n){ return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.'); }

  // Unlocked: render one price cell from its data-usd (single source of truth).
  function renderPriceCell(cell){
    var usd = parseFloat(cell.getAttribute('data-usd'));
    var html = '';
    if(cell.getAttribute('data-from')) html += '<span class="pre">' + L.from + '</span>';
    html += '<span class="usd">US$ ' + fmtN(usd) + '</span>';
    var unit = cell.getAttribute('data-unit');
    if(unit === 'month') html += '<span class="unit">' + L.per_month + '</span>';
    else if(unit === 'cpm') html += '<span class="unit">CPM</span>';
    if(blueRate) html += '<span class="ars">≈ AR$ ' + fmtN(usd * blueRate) + '</span>';
    cell.innerHTML = html;
  }

  // Locked (public): merge each table's price column into a single cell (rowspan)
  // with one "Cotizar" mailto link. Unlocked (team): each row shows its own price.
  function renderPrices(){
    var tables = document.querySelectorAll('table.rate');
    for(var t=0;t<tables.length;t++){
      var cells = tables[t].querySelectorAll('.pr');
      var i;
      if(unlocked){
        for(i=0;i<cells.length;i++){
          cells[i].style.display = '';
          cells[i].removeAttribute('rowspan');
          cells[i].classList.remove('quote-cell');
          renderPriceCell(cells[i]);
        }
      } else {
        var cat = '';
        var catEl = tables[t].closest ? tables[t].closest('.rate-cat') : null;
        if(catEl){ var h = catEl.querySelector('h3'); if(h) cat = h.textContent.replace(/\s+/g,' ').trim(); }
