  // ARS reference at the day's blue rate (dolarapi.com). On failure prices stay USD-only.
  (function loadBlue(){
    var controller = new AbortController();
    var timer = setTimeout(function(){ controller.abort(); }, 5000);
    fetch('https://dolarapi.com/v1/dolares/blue', { signal: controller.signal })
      .then(function(r){ clearTimeout(timer); if(!r.ok) throw new Error(r.status); return r.json(); })
      .then(function(d){ if(d && d.venta > 0){ blueRate = d.venta; renderPrices(); } })
      .catch(function(){ clearTimeout(timer); });
  })();

  // Team gate: reveal prices only for logged-in members with the `equipo` label —
  // same mechanism as /analytics (SHA-256 of email vs the `team` array in ga4-data.json).
  (function gate(){
    if(!(window.crypto && crypto.subtle)) return; // no subtle crypto -> stays locked (public)
    function sha256(str){
      return crypto.subtle.digest('SHA-256', new TextEncoder().encode(str.toLowerCase().trim()))
        .then(function(buf){ return Array.from(new Uint8Array(buf)).map(function(b){ return b.toString(16).padStart(2,'0'); }).join(''); });
    }
    function getTeamData(){
      var c = new AbortController();
      var t = setTimeout(function(){ c.abort(); }, 5000);
      return fetch('https://webhook-hreflang.onrender.com/api/ga4-data.json', { signal: c.signal })
        .then(function(r){ clearTimeout(t); if(!r.ok) throw new Error(r.status); return r.json(); })
        .catch(function(){ clearTimeout(t); return fetch('https://www.421.news/assets/data/ga4-data.json').then(function(r){ return r.json(); }); });
    }
    Promise.all([
      fetch('/members/api/member/', { credentials: 'same-origin' }).then(function(r){ if(!r.ok) throw new Error('no'); return r.json(); }),
      getTeamData()
    ]).then(function(res){
      var member = res[0], data = res[1];
      var team = (data && data.team) ? data.team : [];
      if(!member || !member.email) return;
      return sha256(member.email).then(function(hash){
        if(team.indexOf(hash) !== -1){ unlocked = true; document.body.classList.add('team'); renderPrices(); }
      });
    }).catch(function(){ /* not logged in / no access -> stays locked */ });
  })();
})();
</script>

</body>
</html>
